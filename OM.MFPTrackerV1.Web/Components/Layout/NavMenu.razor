@using Microsoft.AspNetCore.Authorization
@inject NavigationManager Navigation
@rendermode InteractiveServer
@attribute [AllowAnonymous]
<div class="nav-scrollable">
    <nav class="nav flex-column">

        <!-- Home -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="#" Match="NavLinkMatch.All">
                <span><span class="bi bi-shop"></span>Home</span>
            </NavLink>
        </div>

        <!-- People Group -->
        <div class="nav-item px-3">
            <button class="btn btn-link nav-link w-100 text-start d-flex justify-content-between align-items-center"
                    @onclick="TogglePeople">
                <span><span class="bi bi-signpost-2"></span> Management</span>
                <span class="chevron @(isPeopleOpen ? "rotate" : "")">▾</span>
            </button>
            @if (isPeopleOpen)
            {
                <div class="ps-3">
                    <NavLink class="nav-link" href="/mf-categories">Fund Category</NavLink>
                    <NavLink class="nav-link" href="/amcs">AMC</NavLink>
                </div>
            }
        </div>

        <!-- Mutual Funds Group -->
        <div class="nav-item px-3">
            <button class="btn btn-link nav-link w-100 text-start d-flex justify-content-between align-items-center"
                    @onclick="ToggleFunds">
                <span><span class="bi bi-ticket-perforated"></span> Mutual Funds</span>
                <span class="chevron @(isFundsOpen ? "rotate" : "")">▾</span>
            </button>
            @if (isFundsOpen)
            {
                <div class="ps-3">
                    <NavLink class="nav-link" href="/mf-funds">Funds</NavLink>
                    <NavLink class="nav-link" href="/mf-folios">Folio</NavLink>
                    <NavLink class="nav-link" href="/folio-transactions">Transactions</NavLink>
                </div>
            }
        </div>
        <!-- Analysis MFunds Group -->
        <div class="nav-item px-3">
            <button class="btn btn-link nav-link w-100 text-start d-flex justify-content-between align-items-center"
                    @onclick="ToggleAnalysis">
                <span><span class="bi bi-graph-up-arrow"></span> Analysis</span>
                <span class="chevron @(isAnalysisOpen ? "rotate" : "")">▾</span>
            </button>
            @if (isAnalysisOpen)
            {
                <div class="ps-3">
                    <NavLink class="nav-link" href="/transactions-bubble-filters">Investments</NavLink>
                    <NavLink class="nav-link" href="/transactions-explorer">Explorer</NavLink>
                    <NavLink class="nav-link" href="/#">Test</NavLink>
                </div>
            }
        </div>
        <!--Next Icon <i class="bi bi-bezier2"></i> -->
        <!-- Import Group -->
        <div class="nav-item px-3">
            <button class="btn btn-link nav-link w-100 text-start d-flex justify-content-between align-items-center"
                    @onclick="ToggleImports">
                <span><span class="bi bi-clipboard2-data"></span>Imports & Export</span>
                <span class="chevron @(isImportOpen ? "rotate" : "")">▾</span>
            </button>
            @if (isImportOpen)
            {
                <div class="ps-3">
                    <NavLink class="nav-link" href="/admin/nav-sync">Nav Import</NavLink>
                    <NavLink class="nav-link" href="/imports/folio-transactions">Translocations</NavLink>

                </div>
            }
        </div>

        <!-- NAVs Group -->
        <div class="nav-item px-3">
            <button class="btn btn-link nav-link w-100 text-start d-flex justify-content-between align-items-center"
                    @onclick="ToggleNavs">
                <span><span class="bi bi-speedometer"></span>Admin</span>
                <span class="chevron @(isNavsOpen ? "rotate" : "")">▾</span>
            </button>
            @if (isNavsOpen)
            {
                <div class="ps-3">
                    <NavLink class="nav-link" href="/folio-holders">Folio Holders</NavLink>
                    <NavLink class="nav-link" href="/folio-owners">Folio Owner (D)</NavLink>
                    <NavLink class="nav-link" href="/admin/nav">NAV Mgmt</NavLink>
                    <NavLink class="nav-link" href="/admin/special-events">Special Events</NavLink>
                </div>
            }
        </div>
        <!-- Login/LogOut Links -->
        <AuthorizeView>
            <Authorized Context="auth">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/logout">
                        <span><span class="bi bi-door-closed-fill"></span>Logout [@(auth.User.Identity?.Name is { Length: > 5 } n ? n[..5] : auth.User.Identity?.Name)]</span>
                    </NavLink>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/login">
                        <span><span class="bi bi-door-open-fill"></span>Login</span>
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private bool isPeopleOpen;
    private bool isFundsOpen;
    private bool isNavsOpen;
    private bool isAnalysisOpen;
    private bool isImportOpen;

    protected override void OnInitialized()
    {
        // Auto-expand group based on current route
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (uri.StartsWith("people", StringComparison.OrdinalIgnoreCase)) isPeopleOpen = true;
        if (uri.StartsWith("funds") || uri.StartsWith("categories", StringComparison.OrdinalIgnoreCase)) isFundsOpen = true;
        if (uri.StartsWith("navs", StringComparison.OrdinalIgnoreCase)) isNavsOpen = true;
        if (uri.StartsWith("Imports", StringComparison.OrdinalIgnoreCase)) isNavsOpen = true;
    }

    private void TogglePeople() => isPeopleOpen = !isPeopleOpen;
    private void ToggleFunds() => isFundsOpen = !isFundsOpen;
    private void ToggleNavs() => isNavsOpen = !isNavsOpen;
    private void ToggleAnalysis() => isAnalysisOpen = !isAnalysisOpen;
    private void ToggleImports() => isImportOpen = !isImportOpen;
}

