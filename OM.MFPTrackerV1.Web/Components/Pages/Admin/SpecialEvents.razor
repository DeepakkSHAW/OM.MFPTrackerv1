@page "/admin/special-events"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services

@inject ISpecialEventRepo Repo
@inject IMFFundRepo FundRepo
@inject IJSRuntime JS

<h4 class="mt-2 mb-3">Special Events</h4>

<!-- ===================== Toolbar ===================== -->
<div class="row g-2 align-items-end mb-3">
    <div class="col-md-4">
        <label class="form-label small fw-bold">Search</label>
        <input class="form-control"
               placeholder="Title or description"
               @bind="searchText"
               @bind:event="oninput"
               @bind:after="OnSearchChanged" />
    </div>

    <div class="col-md-2">
        <label class="form-label small fw-bold">Event Type</label>
        <select class="form-select"
                @bind="eventType"
                @bind:after="Reload">
            <option value="">All</option>
            @foreach (var t in EventTypes)
            {
                <option value="@t">@t</option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label small fw-bold">Severity</label>
        <select class="form-select"
                @bind="severity"
                @bind:after="Reload">
            <option value="">All</option>
            @foreach (var s in Severities)
            {
                <option value="@s">@s</option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label small fw-bold">Fund</label>
        <select class="form-select"
                @bind="fundId"
                @bind:after="Reload">
            <option value="">Market-wide</option>
            @foreach (var f in funds)
            {
                <option value="@f.FundId">@f.FundName</option>
            }
        </select>
    </div>

    <div class="col text-end">
        <button class="btn btn-primary" @onclick="OpenAdd">
            Add Event
        </button>
    </div>
</div>

<!-- ===================== Table ===================== -->
<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th role="button" @onclick="@(() => SortBy(nameof(SpecialEvent.EventDate)))">
                    Date @SortIcon(nameof(SpecialEvent.EventDate))
                </th>

                <th role="button" @onclick="@(() => SortBy(nameof(SpecialEvent.Title)))">
                    Title @SortIcon(nameof(SpecialEvent.Title))
                </th>

                <th role="button" @onclick="@(() => SortBy("Fund"))">
                    Fund @SortIcon("Fund")
                </th>

                <th role="button" @onclick="@(() => SortBy(nameof(SpecialEvent.EventType)))">
                    Type @SortIcon(nameof(SpecialEvent.EventType))
                </th>

                <th role="button" @onclick="@(() => SortBy(nameof(SpecialEvent.Severity)))">
                    Severity @SortIcon(nameof(SpecialEvent.Severity))
                </th>

                <th style="width:140px;"></th>
            </tr>
        </thead>

        <tbody>
            @if (items.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">
                        No records found.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var e in items)
                {
                    <tr>
                        <td>@e.EventDate.ToString("dd-MMM-yyyy")</td>
                        <td class="text-truncate" style="max-width:200px" title="@e.Title">@Truncate(e.Title)</td>
                        <td title="@(e.Fund?.FundName ?? "Market")">@Truncate(e.Fund?.FundName ?? "Market")</td>
                        <td>
                            <span class="@EventTypeClass(e.EventType)">
                                @e.EventType
                            </span>
                        </td>

                        <td>
                            <span class="@SeverityClass(e.Severity)">
                                @e.Severity
                            </span>
                        </td>

                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-secondary me-2"
                                    @onclick="@(() => OpenEdit(e))">
                                Edit
                            </button>

                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="@(() => ConfirmDelete(e.SpecialEventId))">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- ===================== Pagination ===================== -->
<div class="d-flex align-items-center mt-2">
    <span class="text-muted small">
        Total: @totalCount
    </span>

    <div class="ms-auto d-flex align-items-center gap-2">

        <!-- Page Size Selector -->
        <label class="small text-muted mb-0">Page size</label>
        <select class="form-select form-select-sm"
                style="width:90px"
                @bind="pageSize"
                @bind:after="OnPageSizeChanged">
            <option value="10">10</option>
            <option value="20">20</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>

        <!-- Navigation -->
        <button class="btn btn-sm btn-outline-primary"
                disabled="@(pageNumber == 1)"
                @onclick="PrevPage">
            ‹
        </button>

        <span class="btn btn-sm btn-outline-secondary disabled">
            Page @pageNumber
        </span>

        <button class="btn btn-sm btn-outline-primary"
                disabled="@((pageNumber * pageSize) >= totalCount)"
                @onclick="NextPage">
            ›
        </button>
    </div>
</div>

<!-- ===================== Modal ===================== -->
@if (showModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header py-2">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>

                <div class="modal-body">
                    <EditForm Model="@editModel" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="row g-3">

                            <div class="col-md-4">
                                <label class="form-label">Date</label>
                                <InputDate class="form-control"
                                           @bind-Value="editModel.EventDate" />
                            </div>

                            <div class="col-md-8">
                                <label class="form-label">Title</label>
                                <InputText class="form-control"
                                           @bind-Value="editModel.Title" />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label">Description</label>
                                <InputTextArea class="form-control"
                                               rows="2"
                                               @bind-Value="editModel.Description" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Event Type</label>
                                <InputSelect class="form-select"
                                             @bind-Value="editModel.EventType">
                                    @foreach (var t in EventTypes)
                                    {
                                        <option value="@t">@t</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Severity</label>
                                <InputSelect class="form-select"
                                             @bind-Value="editModel.Severity">
                                    @foreach (var s in Severities)
                                    {
                                        <option value="@s">@s</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Fund</label>
                                <InputSelect class="form-select"
                                             @bind-Value="editModel.FundId">
                                    <option value="">Market-wide</option>
                                    @foreach (var f in funds)
                                    {
                                        <option value="@f.FundId">@f.FundName</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="text-end mt-3">
                            <button type="button"
                                    class="btn btn-outline-secondary me-2"
                                    @onclick="CloseModal">
                                Cancel
                            </button>

                            <button type="submit"
                                    class="btn btn-primary">
                                Save
                            </button>
                        </div>
                    </EditForm>
                </div>

            </div>
        </div>
    </div>
}

@code {

    // ===================== Constants =====================
    private static readonly string[] EventTypes =
        { "Market", "Regulatory", "Fund", "Macro" };

    private static readonly string[] Severities =
        { "Info", "Warning", "Critical" };

    // ===================== State =====================
    private List<SpecialEvent> items = new();
    private List<Fund> funds = new();

    private string? searchText;
    private string? eventType;
    private string? severity;
    private int? fundId;

    private string sortBy = nameof(SpecialEvent.EventDate);
    private bool sortDesc = true;

    private int pageNumber = 1;
    private int pageSize = 10;
    private int totalCount;

    private bool showModal;
    private string modalTitle = "";
    private EditModel editModel = new();

    // ===================== Init =====================
    protected override async Task OnInitializedAsync()
    {
        funds = (await FundRepo.GetAsync(null, null, false, 1, 500)).Items.ToList();
        await Reload();
    }
    private async Task OnPageSizeChanged()
    {
        pageNumber = 1;   // reset page
        await Reload();
    }

    // ===================== Data =====================
    private async Task Reload()
    {
        var r = await Repo.GetAsync(
            searchText,
            eventType,
            severity,
            fundId,
            null,
            null,
            sortBy,
            sortDesc,
            pageNumber,
            pageSize);

        items = r.Items.ToList();
        totalCount = r.TotalCount;
    }

    private async Task OnSearchChanged()
    {
        pageNumber = 1;
        await Reload();
    }

    // ===================== Sorting =====================
    private void SortBy(string field)
    {
        if (sortBy == field)
            sortDesc = !sortDesc;
        else
        {
            sortBy = field;
            sortDesc = false;
        }

        _ = Reload();
    }

    private RenderFragment SortIcon(string field) => b =>
    {
        if (sortBy == field)
            b.AddContent(0, sortDesc ? " ▼" : " ▲");
    };

    // ===================== Paging =====================
    private async Task PrevPage()
    {
        if (pageNumber > 1)
        {
            pageNumber--;
            await Reload();
        }
    }

    private async Task NextPage()
    {
        if (pageNumber * pageSize < totalCount)
        {
            pageNumber++;
            await Reload();
        }
    }

    // ===================== Modal =====================
    private void OpenAdd()
    {
        editModel = new EditModel
        {
            EventDate = DateTime.Today,
            EventType = "Market",
            Severity = "Info"
        };

        modalTitle = "Add Event";
        showModal = true;
    }

    private void OpenEdit(SpecialEvent e)
    {
        editModel = new EditModel
        {
            SpecialEventId = e.SpecialEventId,
            EventDate = e.EventDate,
            Title = e.Title,
            Description = e.Description,
            EventType = e.EventType,
            Severity = e.Severity,
            FundId = e.FundId
        };

        modalTitle = "Edit Event";
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveAsync()
    {
        var entity = editModel.ToEntity();

        if (entity.SpecialEventId == 0)
            await Repo.AddAsync(entity);
        else
            await Repo.UpdateAsync(entity);

        showModal = false;
        await Reload();
    }

    private async Task ConfirmDelete(int id)
    {
        if (await JS.InvokeAsync<bool>(
            "confirm", "Delete this event?"))
        {
            await Repo.DeleteAsync(id);
            await Reload();
        }
    }

    // ===================== Styling =====================
    private string SeverityClass(string s) => s switch
    {
        "Critical" => "badge bg-danger",
        "Warning" => "badge bg-warning text-dark",
        "Info" => "badge bg-info",
        _ => "badge bg-secondary"
    };

    private string EventTypeClass(string t) => t switch
    {
        "Market" => "badge bg-primary",
        "Regulatory" => "badge bg-secondary",
        "Fund" => "badge bg-success",
        "Macro" => "badge bg-dark",
        _ => "badge bg-light text-dark"
    };

    // ===================== Edit Model =====================
    public sealed class EditModel
    {
        public int SpecialEventId { get; set; }

        [Required]
        public DateTime EventDate { get; set; }

        [Required, StringLength(100)]
        public string Title { get; set; } = "";

        [StringLength(500)]
        public string? Description { get; set; }

        [Required]
        public string EventType { get; set; } = "Market";

        [Required]
        public string Severity { get; set; } = "Info";

        public int? FundId { get; set; }

        public SpecialEvent ToEntity() => new()
        {
            SpecialEventId = SpecialEventId,
            EventDate = EventDate,
            Title = Title.Trim(),
            Description = Description?.Trim(),
            EventType = EventType,
            Severity = Severity,
            FundId = FundId
        };
    }
    private static string Truncate(string? text, int maxLength = 20)
    {
        if (string.IsNullOrWhiteSpace(text))
            return string.Empty;

        return text.Length <= maxLength
            ? text
            : text.Substring(0, maxLength) + "…";
    }
}