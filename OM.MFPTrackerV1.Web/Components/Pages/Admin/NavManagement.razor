@page "/admin/nav"

@using System.ComponentModel.DataAnnotations
@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services

@inject IFundNavRepo Repo
@inject IMFFundRepo FundRepo
@inject IAmfiNavService NavService
@inject IJSRuntime JS

<h4 class="mt-2 mb-3">NAV Management</h4>

<!-- ===================== TOOLBAR ===================== -->
<div class="row g-2 align-items-end mb-3">

    <div class="col-md-4">
        <label class="form-label small fw-bold">Fund</label>
        <select class="form-select"
                @bind="selectedFundId"
                @bind:after="OnFundChanged">
            <option value="">All Funds</option>
            @foreach (var f in funds)
            {
                <option value="@f.FundId">@f.FundName</option>
            }
        </select>
    </div>

    <div class="col text-end">
        <button class="btn btn-primary me-2" @onclick="OpenAdd">
            Add NAV
        </button>
        <button class="btn btn-outline-primary" @onclick="OpenImport">
            Import CSV
        </button>
    </div>

</div>

<!-- ===================== NAV GRID ===================== -->
<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">

        <thead class="table-light">
            <tr>
                <th role="button" @onclick="@(() => SortBy(nameof(FundNav.NavDate)))">
                    Date @SortIcon(nameof(FundNav.NavDate))
                </th>
                <th role="button" @onclick="@(() => SortBy("Fund"))">
                    Fund @SortIcon("Fund")
                </th>
                <th class="text-end" role="button" @onclick="@(() => SortBy(nameof(FundNav.NavValue)))">
                    NAV @SortIcon(nameof(FundNav.NavValue))
                </th>
                <th style="width:120px"></th>
            </tr>
        </thead>

        <tbody>
            @if (items.Count == 0)
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">
                        No NAV data found.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var n in items)
                {
                    <tr>
                        <td>@n.NavDate.ToString("dd-MMM-yyyy")</td>
                        <td title="@n.Fund.FundName">
                            @Truncate(n.Fund.FundName)
                        </td>
                        <td class="text-end">@n.NavValue</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-secondary me-2"
                                    @onclick="@(() => OpenEdit(n))">
                                Edit
                            </button>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="@(() => Delete(n.FundNavId))">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>

    </table>
</div>

<!-- ===================== PAGINATION ===================== -->
<div class="d-flex align-items-center mt-2">
    <span class="text-muted small">
        Total: @totalCount
    </span>

    <div class="ms-auto d-flex align-items-center gap-2">

        <select class="form-select form-select-sm"
                style="width:90px"
                @bind="pageSize"
                @bind:after="OnPageSizeChanged">
            <option>10</option>
            <option>20</option>
            <option>50</option>
            <option>100</option>
        </select>

        <button class="btn btn-sm btn-outline-primary"
                disabled="@(pageNumber == 1)"
                @onclick="PrevPage">
            ‹
        </button>

        <span class="btn btn-sm btn-outline-secondary disabled">
            Page @pageNumber
        </span>

        <button class="btn btn-sm btn-outline-primary"
                disabled="@((pageNumber * pageSize) >= totalCount)"
                @onclick="NextPage">
            ›
        </button>
    </div>
</div>

<!-- ===================== ADD / EDIT MODAL ===================== -->
@if (showEditModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header py-2">
                    <h5 class="modal-title">@editModalTitle</h5>
                    <button class="btn-close" @onclick="CloseEdit"></button>
                </div>

                <div class="modal-body">
                    <EditForm Model="@editModel" OnValidSubmit="SaveNav">
                        <DataAnnotationsValidator />

                        <label class="form-label">Fund</label>
                        <InputSelect class="form-select"
                                     @bind-Value="editModel.FundId">
                            @foreach (var f in funds)
                            {
                                <option value="@f.FundId">@f.FundName</option>
                            }
                        </InputSelect>

                        <label class="form-label mt-2">Date</label>
                        <InputDate class="form-control"
                                   @bind-Value="editModel.NavDate" />

                        <label class="form-label mt-2">NAV</label>
                        <InputNumber class="form-control"
                                     step="0.0001"
                                     @bind-Value="editModel.NavValue" />

                        <div class="text-end mt-3">
                            <button type="submit" class="btn btn-primary">
                                Save
                            </button>
                        </div>

                    </EditForm>
                </div>

            </div>
        </div>
    </div>
}

<!-- ===================== CSV IMPORT MODAL ===================== -->
@if (showImportModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header py-2">
                    <h5 class="modal-title">Import NAV (CSV)</h5>
                    <button class="btn-close" @onclick="CloseImport"></button>
                </div>

                <div class="modal-body">

                    <p class="text-muted small">
                        CSV format:<br />
                        <code>FundCode,NavDate,NavValue</code>
                    </p>

                    <InputFile OnChange="HandleCsvSelected" />

                    @if (showPreview)
                    {
                        <hr />

                        <h6>Preview (first @previewRows.Count rows)</h6>

                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>FundCode</th>
                                        <th>Date</th>
                                        <th>NAV</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in previewRows)
                                    {
                                        <tr>
                                            <td>@r.FundCode</td>
                                            <td>@r.NavDate.ToString("dd-MMM-yyyy")</td>
                                            <td>@r.NavValue</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="alert alert-info mt-3">
                            @previewSummary.ToString()
                        </div>

                        <div class="text-end mt-3">
                            <button class="btn btn-secondary me-2"
                                    @onclick="CloseImport">
                                Cancel
                            </button>
                            <button class="btn btn-primary"
                                    @onclick="ConfirmImport">
                                Confirm Import
                            </button>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
}

@code {

    /* ===================== GRID STATE ===================== */
    private List<FundNav> items = new();
    private List<Fund> funds = new();
    private int? selectedFundId;

    private string sortBy = nameof(FundNav.NavDate);
    private bool sortDesc = true;

    private int pageNumber = 1;
    private int pageSize = 10;
    private int totalCount;

    protected override async Task OnInitializedAsync()
    {
        funds = (await FundRepo.GetAsync(null, null, false, 1, 2000)).Items.ToList();
        await Reload();
    }

    private async Task Reload()
    {
        var r = await Repo.GetAsync(
            selectedFundId,
            null,
            null,
            sortBy,
            sortDesc,
            pageNumber,
            pageSize);

        items = r.Items.ToList();
        totalCount = r.TotalCount;
    }

    private async Task OnFundChanged()
    {
        pageNumber = 1;
        await Reload();
    }

    private void SortBy(string field)
    {
        sortDesc = (sortBy == field) ? !sortDesc : false;
        sortBy = field;
        _ = Reload();
    }

    private RenderFragment SortIcon(string field) => b =>
    {
        if (sortBy == field)
            b.AddContent(0, sortDesc ? " ▼" : " ▲");
    };

    private async Task PrevPage()
    {
        if (pageNumber > 1)
        {
            pageNumber--;
            await Reload();
        }
    }

    private async Task NextPage()
    {
        if (pageNumber * pageSize < totalCount)
        {
            pageNumber++;
            await Reload();
        }
    }

    private async Task OnPageSizeChanged()
    {
        pageNumber = 1;
        await Reload();
    }

    private static string Truncate(string text, int max = 20)
        => text.Length <= max ? text : text[..max] + "…";

    /* ===================== ADD / EDIT ===================== */
    private bool showEditModal;
    private string editModalTitle = "";
    private NavEditModel editModel = new();

    private void OpenAdd()
    {
        editModel = new NavEditModel { NavDate = DateTime.Today };
        editModalTitle = "Add NAV";
        showEditModal = true;
    }

    private void OpenEdit(FundNav n)
    {
        editModel = new NavEditModel
        {
            FundNavId = n.FundNavId,
            FundId = n.FundId,
            NavDate = n.NavDate,
            NavValue = n.NavValue
        };
        editModalTitle = "Edit NAV";
        showEditModal = true;
    }

    private void CloseEdit() => showEditModal = false;

    private async Task SaveNav()
    {
        var entity = editModel.ToEntity();

        if (entity.FundNavId == 0)
            await Repo.AddAsync(entity);
        else
            await Repo.UpdateAsync(entity);

        CloseEdit();
        await Reload();
    }

    private async Task Delete(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Delete this NAV entry?"))
        {
            await Repo.DeleteAsync(id);
            await Reload();
        }
    }

    private sealed class NavEditModel
    {
        public int FundNavId { get; set; }
        public int FundId { get; set; }
        [Required] public DateTime NavDate { get; set; }
        [Required] public decimal NavValue { get; set; }

        public FundNav ToEntity() => new()
        {
            FundNavId = FundNavId,
            FundId = FundId,
            NavDate = NavDate,
            NavValue = NavValue
        };
    }

    /* ===================== CSV IMPORT ===================== */
    private bool showImportModal;
    private bool showPreview;
    private IBrowserFile? csvFile;

    private List<NavCsvPreviewRow> previewRows = new();
    private NavSyncSummary previewSummary = new();

    private sealed class NavCsvPreviewRow
    {
        public string FundCode { get; set; } = "";
        public DateTime NavDate { get; set; }
        public decimal NavValue { get; set; }
    }

    private void OpenImport()
    {
        csvFile = null;
        previewRows.Clear();
        previewSummary = new NavSyncSummary();
        showPreview = false;
        showImportModal = true;
    }

    private void CloseImport()
    {
        showImportModal = false;
        showPreview = false;
    }

    private async Task HandleCsvSelected(InputFileChangeEventArgs e)
    {
        csvFile = e.File;
        previewRows.Clear();

        using var reader = new StreamReader(csvFile.OpenReadStream());
        string? line;
        bool skipHeader = true;

        while ((line = await reader.ReadLineAsync()) != null &&
               previewRows.Count < 50)
        {
            if (skipHeader)
            {
                skipHeader = false;
                continue;
            }

            var parts = line.Split(',');
            if (parts.Length != 3)
                continue;

            if (!DateTime.TryParse(parts[1], out var date) ||
                !decimal.TryParse(parts[2], out var nav))
                continue;

            previewRows.Add(new NavCsvPreviewRow
            {
                FundCode = parts[0].Trim(),
                NavDate = date,
                NavValue = nav
            });
        }

        previewSummary = new NavSyncSummary
        {
            Inserted = previewRows.Count
        };

        showPreview = previewRows.Count > 0;
    }

    private async Task ConfirmImport()
    {
        if (csvFile == null)
            return;

        await NavService.ImportNavFromCsvAsync(
            csvFile.OpenReadStream());

        CloseImport();
        await Reload();
    }
}