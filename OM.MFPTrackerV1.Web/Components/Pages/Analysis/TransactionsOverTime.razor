@page "/TransactionsOverTime"
@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services
@using OM.MFPTrackerV1.Web.Helpers
@rendermode InteractiveServer
@attribute [Authorize(Roles = "User,Admin")]

@inject IMutualFundTransactionRepo TxnRepo
@inject NavigationManager Nav

<!-- ================= FILTER CARD ================= -->

<div class="d-flex justify-content-between align-items-center mb-3">

    <!-- LEFT: Title + Range Info -->
    <div>
        <h5 class="mb-0">
            Investment Trends (Timeline)
        </h5>
        <div class="text-muted" style="font-size: 0.75rem;">
            @fromDate.ToString("dd MMM yyyy") → @toDate.ToString("dd MMM yyyy") •
            @DateParser.TimeRanges.First(x => x.Key == selectedRange).Value
        </div>
    </div>

    <!-- RIGHT: Range Dropdown + Toggle -->
    <div class="d-flex align-items-center gap-2">

        <!-- Range dropdown -->
        <select class="form-select form-select-sm w-auto"
                @bind="selectedRange"
                @bind:after="LoadChart">

            @foreach (var r in DateParser.TimeRanges)
            {
                <option value="@r.Key">@r.Value</option>
            }
        </select>

        <!-- Chart/Table toggle -->
        <div class="btn-group btn-group-sm">
            <button class="btn @(viewMode == "chart" ? "btn-primary" : "btn-outline-primary")"
                    @onclick="SetChartView">
                Chart
            </button>

            <button class="btn @(viewMode == "table" ? "btn-primary" : "btn-outline-primary")"
                    @onclick="SetTableView">
                Table
            </button>
        </div>

    </div>

</div>

<!-- ================= CHART / TABLE ================= -->

<div class="card shadow-sm">
    <div class="card-body">
        @if (labels.Length == 0)
        {
            <div class="text-center text-muted py-4">
                No data available. Click <b>Apply</b> to load results.
            </div>
        }
        else if (viewMode == "chart")
        {
            <BarChart Labels="@labels" Data="@values" />
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-sm table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>Period</th>
                            <th class="text-end">Investment (₹)</th>
                        </tr>
                    </thead>

                    <tbody>
                        @for (int i = 0; i < labels.Length; i++)
                        {
                            <tr>
                                <td>@labels[i]</td>
                                <td class="text-end">
                                    @values[i].ToString("N0")
                                </td>
                            </tr>
                        }
                    </tbody>

                    <tfoot>
                        <tr class="fw-bold">
                            <td>Total</td>
                            <td class="text-end">
                                @values.Sum().ToString("N0")
                            </td>
                        </tr>
                    </tfoot>

                </table>

            </div>
        }

    </div>
</div>

@code {

    private string viewMode = "chart";
    private DateTime fromDate;
    private DateTime toDate;
    private string groupBy = "M";

    private string[] labels = [];
    private double[] values = [];
    private string selectedRange = "1Y";

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("range", out var value))
        {
            selectedRange = value.ToString();
        }

        // ✅ derive everything from helper
        var (from, to) = selectedRange.GetDateRange();

        fromDate = from;
        toDate = to;

        groupBy = DateParser.GetGrouping(selectedRange);  // ✅ new

        await LoadChart();
    }

    private async Task LoadChart()
    {
        // ✅ always recalc from range
        var (from, to) = selectedRange.GetDateRange();

        fromDate = from;
        toDate = to;

        groupBy = DateParser.GetGrouping(selectedRange);

        var trend = await TxnRepo.GetInvestmentTrendAsync(
            new TransactionFilter
            {
                StartDate = fromDate,
                EndDate = toDate
            },
            groupBy
        );

        labels = trend
            .Select(x => FormatLabel(x.Period))
            .ToArray();

        values = trend
            .Select(x => (double)x.Amount)
            .ToArray();
    }


    private string FormatLabel(DateTime dt)
    {
        // ✅ Weekly → show date range
        if (groupBy == "W")
        {
            var start = dt;
            var end = dt.AddDays(6);

            return $"{start:dd MMM} - {end:dd MMM}";
        }

        // ✅ Quarterly
        if (groupBy == "Q")
        {
            int quarter = ((dt.Month - 1) / 3) + 1;
            return $"Q{quarter} {dt:yyyy}";
        }

        // ✅ Yearly
        if (groupBy == "Y")
        {
            return dt.ToString("yyyy");
        }

        // ✅ Monthly (default)
        return dt.ToString("MMM yyyy");
    }

    private void SetChartView() => viewMode = "chart";
    private void SetTableView() => viewMode = "table";
}