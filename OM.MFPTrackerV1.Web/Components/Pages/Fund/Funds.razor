<!-- Filters -->
<div class="card mb-3">
    <div class="card-body">

        <!-- Row 1: Text filters -->
        <div class="row g-2 mb-2">
            <div class="col-md-3">
                <label class="form-label mb-0 small fw-semibold">Fund name</label>
                <input class="form-control form-control-sm" @bind="filterName" placeholder="e.g., Small Cap" />
            </div>
            <div class="col-md-3">
                <label class="form-label mb-0 small fw-semibold">AMC</label>
                <input class="form-control form-control-sm" @bind="filterAMC" placeholder="e.g., Axis" />
            </div>
            <div class="col-md-2">
                <label class="form-label mb-0 small fw-semibold">Scheme code</label>
                <input class="form-control form-control-sm" @bind="filterScheme" placeholder="e.g., 125" />
            </div>
            <div class="col-md-2">
                <label class="form-label mb-0 small fw-semibold">ISIN</label>
                <input class="form-control form-control-sm" @bind="filterISIN" placeholder="e.g., INF" />
            </div>
        </div>

        <!-- Row 2: Category + Flags + Buttons -->
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label mb-0 small fw-semibold">Category</label>
                <select class="form-select form-select-sm" @bind="filterCatId">
                    <option value="0">All</option>
                    @foreach (var c in _cats ?? Enumerable.Empty<MFCategory>())
                    {
                        <option value="@c.MFCatId">@c.CategoryName</option>
                    }
                </select>
            </div>

            <div class="col-md-3 d-flex align-items-center gap-3">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="txnOnly" @bind="filterTxnOnly" />
                    <label class="form-check-label small" for="txnOnly">Txn Allowed</label>
                </div>
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="navOnly" @bind="filterNavOnly" />
                    <label class="form-check-label small" for="navOnly">NAV Allowed</label>
                </div>
            </div>

            <div class="col-md-6 d-flex justify-content-end gap-2">
                <button class="btn btn-sm btn-primary" @onclick="ApplyFilters">Search</button>
                <button class="btn btn-sm btn-secondary" @onclick="ClearFilters">Clear</button>
            </div>
        </div>

    </div>
</div>
<!-- Table -->
<table class="table table-sm table-striped align-middle">
    <thead class="table-head-sm-bold">
        <tr>
            <th aria-sort="@AriaSort("FundName")">
                <div class="th-sort d-flex align-items-center"
                     role="button"
                     title="Sort by Fund"
                     @onclick='() => Sort("FundName")'>
                    <span class="th-title">Fund</span>
                    <span class="th-caret">@((MarkupString)SortGlyph("FundName").Value)</span>
                </div>
            </th>

            <th aria-sort="@AriaSort("AMCName")">
                <div class="th-sort d-flex align-items-center"
                     role="button"
                     title="Sort by AMC"
                     @onclick='() => Sort("AMCName")'>
                    <span class="th-title">AMC</span>
                    <span class="th-caret">@((MarkupString)SortGlyph("AMCName").Value)</span>
                </div>
            </th>

            <th aria-sort="@AriaSort("SchemeCode")" style="width:160px;">
                <div class="th-sort d-flex align-items-center"
                     role="button"
                     title="Sort by Scheme Code"
                     @onclick='() => Sort("SchemeCode")'>
                    <span class="th-title">Scheme Code</span>
                    <span class="th-caret">@((MarkupString)SortGlyph("SchemeCode").Value)</span>
                </div>
            </th>

            <th aria-sort="@AriaSort("ISIN")" style="width:160px;">
                <div class="th-sort d-flex align-items-center"
                     role="button"
                     title="Sort by ISIN"
                     @onclick='() => Sort("ISIN")'>
                    <span class="th-title">ISIN</span>
                    <span class="th-caret">@((MarkupString)SortGlyph("ISIN").Value)</span>
                </div>
            </th>

            <th aria-sort="@AriaSort("Category")" style="width:260px;">
                <div class="th-sort d-flex align-items-center"
                     role="button"
                     title="Sort by Category"
                     @onclick='() => Sort("Category")'>
                    <span class="th-title">Category</span>
                    <span class="th-caret">@((MarkupString)SortGlyph("Category").Value)</span>
                </div>
            </th>

            <th style="width:130px;">Flags</th>
            <th style="width:160px;"></th>
        </tr>
    </thead>

    <tbody>
        @if (_items is null)
        {
            <tr><td colspan="7">Loading...</td></tr>
        }
        else if (_items.Count == 0)
        {
            <tr><td colspan="7">No data</td></tr>
        }
        else
        {
            @foreach (var x in _items)
            {
                <tr>
                    <td>@x.FundName</td>
                    <td>@x.AMCName</td>
                    <td>@x.SchemeCode</td>
                    <td>@x.ISIN</td>
                    <td>@x.Category?.CategoryName</td>
                    <td>
                        <span class="badge bg-@(x.IsTransactionAllowed ? "success" : "secondary")">Txn</span>
                        <span class="badge bg-@(x.IsNavAllowed ? "info" : "secondary")">NAV</span>
                    </td>
                    <td class="text-end">
                        <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => OpenEdit(x)">Edit</button>
                        <button class="btn btn-outline-danger btn-sm"
                                @onclick='() => ConfirmDelete(x.FundId, x.FundName)'>
                            Delete
                        </button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<!-- Pagination -->
<div class="d-flex align-items-center justify-content-between">
    <div>
        Showing @FromRow–@ToRow of @totalCount
    </div>
    <div class="d-flex align-items-center gap-2">
        <div class="input-group input-group-sm" style="width:auto;">
            <span class="input-group-text">Page size</span>
            <select class="form-select form-select-sm" style="width:auto" @bind="PageSize">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>

        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(pageNumber == 1 ? "disabled" : null)">
                    <button class="page-link" @onclick="FirstPage">«</button>
                </li>
                <li class="page-item @(pageNumber == 1 ? "disabled" : null)">
                    <button class="page-link" @onclick="PrevPage">‹</button>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @pageNumber of @totalPages</span>
                </li>
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : null)">
                    <button class="page-link" @onclick="NextPage">›</button>
                </li>
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : null)">
                    <button class="page-link" @onclick="LastPage">»</button>
                </li>
            </ul>
        </nav>
    </div>
</div>

@* ---------------- Modal (JS-free; Add & Edit) ---------------- *@
@if (showModal)
{
    <div class="modal fade show" style="display:block;" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content" tabindex="0" @onkeydown="HandleKeyDown">
                <div class="modal-header">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button class="btn-close" @onclick="CloseModal" disabled="@saving"></button>
                </div>

                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(validationMessage))
                    {
                        <div class="alert alert-danger py-1">@validationMessage</div>
                    }

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">Fund Name</label>
                            <input class="form-control" @bind="editModel.FundName" />
                            <small class="text-muted">5–100 chars; unique (case-insensitive)</small>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">AMC</label>
                            <input class="form-control" @bind="editModel.AMCName" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Scheme Code</label>
                            <input class="form-control" @bind="editModel.SchemeCode" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">ISIN</label>
                            <input class="form-control" @bind="editModel.ISIN" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Category</label>
                            <select class="form-select" @bind="editModel.MFCatId">
                                <option value="0">-- Select --</option>
                                @if (_cats is not null)
                                {
                                    @foreach (var c in _cats)
                                    {
                                        <option value="@c.MFCatId">@c.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="txnAllowed" @bind="editModel.IsTransactionAllowed" />
                                <label class="form-check-label" for="txnAllowed">Transaction Allowed</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="navAllowed" @bind="editModel.IsNavAllowed" />
                                <label class="form-check-label" for="navAllowed">NAV Allowed</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseModal" disabled="@saving">Cancel</button>
                    <button class="btn btn-success" @onclick="Save" disabled="@saving">@(saving ? "Saving..." : "Save")</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<Fund>? _items;
    private List<MFCategory>? _cats;

    // Filters
    private string? filterName;
    private string? filterAMC;
    private string? filterScheme;
    private int filterCatId = 0;
    private string? filterISIN;   
    private bool filterTxnOnly = false;
    private bool filterNavOnly = false;

    // Sorting
    private string sortBy = "FundName";
    private bool sortDesc = false;

    // Paging
    private int pageNumber = 1;
    private int _pageSize = 10;
    private int PageSize
    {
        get => _pageSize;
        set { if (_pageSize == value) return; _pageSize = value; pageNumber = 1; _ = Reload(); }
    }
    private int totalCount;
    private int totalPages => Math.Max(1, (int)Math.Ceiling((double)totalCount / _pageSize));
    private int FromRow => totalCount == 0 ? 0 : ((pageNumber - 1) * _pageSize) + 1;
    private int ToRow => Math.Min(pageNumber * _pageSize, totalCount);

    // Modal
    private bool showModal = false;
    private bool isEdit = false;
    private bool saving = false;
    private string modalTitle = "Add Fund";
    private string? validationMessage;
    private Fund editModel = new();

    protected override async Task OnInitializedAsync()
    {
        // Load categories once
        var (cats, catsTotal) = await CatRepo.GetAsync(nameContains: null, skip: 0, take: 500);
        _cats = cats.ToList();
        await Reload();
    }

    private async Task Reload()
    {
        var skip = (pageNumber - 1) * _pageSize;

        var (items, total) = await FundRepo.GetAsync(
            nameContains: filterName,
            amcContains: filterAMC,
            codeContains: filterScheme,
            mfcCatId: filterCatId == 0 ? null : filterCatId,
            onlyTxnAllowed: filterTxnOnly ? true : null,
            onlyNavAllowed: filterNavOnly ? true : null,
            skip: skip,
            take: _pageSize,
            sortBy: sortBy,
            desc: sortDesc,
            isinContains: filterISIN      // <-- NEW optional param
);
        _items = items.ToList();
        totalCount = total;

        if (pageNumber > totalPages && totalPages > 0)
        {
            pageNumber = totalPages;
            await Reload();
            return;
        }
        StateHasChanged();
    }

    private async Task ApplyFilters()
    {
        pageNumber = 1;
        await Reload();
    }

    private async Task ClearFilters()
    {
        filterName = filterAMC = filterScheme = filterISIN = null;
        filterCatId = 0;
        filterTxnOnly = filterNavOnly = false;
        pageNumber = 1;
        await Reload();
    }
    private async Task Sort(string column)
    {
        if (sortBy == column) sortDesc = !sortDesc;
        else { sortBy = column; sortDesc = false; } // text default asc
        pageNumber = 1;
        await Reload();
    }

    private MarkupString SortGlyph(string column)
    {
        if (sortBy != column) return new MarkupString(string.Empty);
        var glyph = sortDesc ? "▼" : "▲";
        return new MarkupString($"<span class=\"ms-1\">{glyph}</span>");
    }

    private string AriaSort(string column) => sortBy != column ? "none" : (sortDesc ? "descending" : "ascending");

    // Paging
    private async Task FirstPage() { if (pageNumber != 1) { pageNumber = 1; await Reload(); } }
    private async Task PrevPage() { if (pageNumber > 1) { pageNumber--; await Reload(); } }
    private async Task NextPage() { if (pageNumber < totalPages) { pageNumber++; await Reload(); } }
    private async Task LastPage() { if (pageNumber < totalPages) { pageNumber = totalPages; await Reload(); } }

    // Modal: Add/Edit
    private void OpenAdd()
    {
        isEdit = false;
        modalTitle = "Add Fund";
        validationMessage = null;
        editModel = new Fund
        {
            IsTransactionAllowed = true,
            IsNavAllowed = true
        };
        showModal = true;
    }

    private void OpenEdit(Fund src)
    {
        isEdit = true;
        modalTitle = "Edit Fund";
        validationMessage = null;

        editModel = new Fund
        {
            FundId = src.FundId,
            FundName = src.FundName,
            SchemeCode = src.SchemeCode,
            ISIN = src.ISIN,
            AMCName = src.AMCName,
            IsTransactionAllowed = src.IsTransactionAllowed,
            IsNavAllowed = src.IsNavAllowed,
            MFCatId = src.MFCatId,
            InDate = src.InDate,
            UpdateDate = src.UpdateDate
        };

        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Escape" or "Esc") showModal = false;
    }

    private async Task Save()
    {
        validationMessage = null;

        // Minimal UI checks
        if (string.IsNullOrWhiteSpace(editModel.FundName)) { validationMessage = "Fund Name is required."; return; }
        if (editModel.FundName.Length < 5 || editModel.FundName.Length > 100) { validationMessage = "Fund Name should be 5–100 characters."; return; }
        if (string.IsNullOrWhiteSpace(editModel.SchemeCode)) { validationMessage = "Scheme Code is required."; return; }
        if (string.IsNullOrWhiteSpace(editModel.ISIN)) { validationMessage = "ISIN is required."; return; }
        if (string.IsNullOrWhiteSpace(editModel.AMCName)) { validationMessage = "AMC Name is required."; return; }
        if (editModel.MFCatId <= 0) { validationMessage = "Category is required."; return; }

        try
        {
            saving = true;

            if (isEdit) await FundRepo.UpdateAsync(editModel);
            else await FundRepo.AddAsync(editModel);

            showModal = false;
            await Reload();
        }
        catch (InvalidOperationException ex)
        {
            validationMessage = ex.Message; // Friendly duplicate messages
        }
        catch (DbUpdateException)
        {
            validationMessage = "Save failed due to a unique constraint or database error. Please check unique fields.";
        }
        catch (Exception ex)
        {
            validationMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ConfirmDelete(int id, string display)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete “{display}”?"))
        {
            await FundRepo.DeleteAsync(id);
            if (_items?.Count == 1 && pageNumber > 1) pageNumber--;
            await Reload();
        }
    }
}