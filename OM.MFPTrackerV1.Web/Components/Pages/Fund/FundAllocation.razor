@page "/fund-allocation"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "User,Admin")]

@using OM.MFPTrackerV1.Data.Services
@using OM.MFPTrackerV1.Web.Components

@inject IMFFundRepo FundRepo
@inject IMutualFundTransactionRepo TxnRepo

<h3>Investment Allocation by Fund</h3>

<p class="text-muted">
    Distribution of total invested amount across all mutual fund schemes.
</p>

@if (isLoading)
{
    <p>Loading data…</p>
}
else if (values.Length == 0)
{
    <div class="alert alert-info">
        No investment data available.
    </div>
}
else
{
    <PieChart Labels="@labels" Values="@values" />
}

@code {

    private string[] labels = [];
    private double[] values = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;

        // 1️⃣ Load master fund list
        var funds = await FundRepo.GetAllAsync();

        // 2️⃣ Load aggregated investment totals
        var totals = await TxnRepo.GetTotalInvestmentByFundAsync();

        // 3️⃣ Shape data for pie chart
        var data = funds
            .Select(f => new
            {
                f.FundName,
                Value = totals.TryGetValue(f.FundId, out var v) ? v : 0m
            })
            .Where(x => x.Value > 0)
            .OrderByDescending(x => x.Value)
            .ToList();

        labels = data
            .Select(x => x.FundName)
            .ToArray();

        values = data
            .Select(x => (double)x.Value)
            .ToArray();

        isLoading = false;
    }
}