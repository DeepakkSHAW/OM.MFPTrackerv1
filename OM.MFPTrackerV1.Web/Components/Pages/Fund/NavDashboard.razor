@page "/nav-dashboard"
@rendermode InteractiveServer

@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services

@inject NavigationManager NavManager
@inject IFundNavRepo FundNavRepo
@inject IMFFundRepo FundLookupRepo
@inject IMutualFundTransactionRepo TransactionRepo
@* Step 3 *@

<h3>NAV Dashboard</h3>

<!-- ================= Controls ================= -->
<div class="card mb-3">
    <div class="card-body">

        <div class="row g-3 align-items-end">

            <!-- Fund selector -->
            <div class="col-md-4">
                <label class="form-label">Fund</label>
                <select class="form-select" @bind="selectedFundId">
                    <option value="">-- Select fund --</option>
                    @foreach (var fund in funds)
                    {
                        <option value="@fund.Id">@fund.Name</option>
                    }
                </select>
            </div>

            <!-- From date -->
            <div class="col-md-3">
                <label class="form-label">From date</label>
                <input type="date"
                       class="form-control"
                       @bind="fromDate" />
            </div>

            <!-- To date -->
            <div class="col-md-3">
                <label class="form-label">To date</label>
                <input type="date"
                       class="form-control"
                       @bind="toDate" />
            </div>

            <!-- Load button -->
            <div class="col-md-2">
                <button class="btn btn-primary w-100"
                        @onclick="LoadNavAsync"
                        disabled="@(!CanLoad)">
                    Load
                </button>
            </div>
        </div>

        <!-- Purchase toggle -->
        <div class="row mt-3">
            <div class="col-md-12">
                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           id="includePurchases"
                           @bind="includePurchases" />

                    <label class="form-check-label" for="includePurchases">
                        Include purchase details
                    </label>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- ================= Chart ================= -->
@if (isLoading)
{
    <p>Loading NAV data…</p>
}
else if (navValues.Length > 0)
{
    <NavLineChart Labels="@labels"
                  NavValues="@navValues"
                  Purchases="@(includePurchases ? purchases : EmptyPurchases)" />
}
else
{
    <p class="text-muted">No data loaded.</p>
}

@code {

    /* ================= UI state ================= */

    private IReadOnlyList<FundLookupDto> funds = [];
    private int? selectedFundId;

    private DateTime fromDate = DateTime.Today.AddMonths(-6);
    private DateTime toDate = DateTime.Today;

    private bool includePurchases;
    private bool isLoading;

    /* ================= Chart data ================= */

    private string[] labels = [];
    private double[] navValues = [];

    private List<NavLineChart.PurchasePoint> purchases = new();

    // ✅ shared empty list (never pass null to JS)
    private static readonly List<NavLineChart.PurchasePoint>
        EmptyPurchases = new();

    /* ================= Lifecycle ================= */
    protected override async Task OnInitializedAsync()
    {
        // ✅ Load funds
        funds = await FundLookupRepo.GetFundsAsync();

        // ✅ Read query param
        ReadQueryParams();

        // ✅ If fund passed → auto load
        if (queryFundId.HasValue)
        {
            selectedFundId = queryFundId;

            fromDate = DateTime.Today.AddYears(-1); // ✅ last 1 year
            toDate = DateTime.Today;

            await LoadNavAsync(); // ✅ auto load
        }
    }
    private bool CanLoad =>
        selectedFundId.HasValue &&
        fromDate < toDate;

    /* ================= Data loading ================= */
    private async Task LoadNavAsync()
    {
        if (!selectedFundId.HasValue)
            return;

        isLoading = true;

        try
        {
            // =========================
            // 1️⃣ Load NAV data
            // =========================
            var navHistory =
                await FundNavRepo.GetNavHistoryAsync(
                    selectedFundId.Value,
                    fromDate,
                    toDate);

            // =========================
            // 2️⃣ Load Transactions
            // =========================
            var (items, _) = await TransactionRepo.GetAsync(
                folioId: null,
                fundId: selectedFundId.Value,
                sortBy: nameof(MutualFundTransaction.TransactionDate),
                sortDesc: false,
                pageNumber: 1,
                pageSize: 10_000);

            var investmentTxns = items
                .Where(tx =>
                    (tx.TxnType == TransactionType.BUY ||
                     tx.TxnType == TransactionType.SIP ||
                     tx.TxnType == TransactionType.SWITCH_IN ||
                     tx.TxnType == TransactionType.DIV_REINVEST) &&
                    tx.TransactionDate.Date >= fromDate.Date &&
                    tx.TransactionDate.Date <= toDate.Date)
                .ToList();

            // =========================
            // 3️⃣ UNIFIED TIMELINE ✅
            // =========================

            var unified = new List<(DateTime date, double nav, bool isTxn, double amount)>();

            // NAV points
            foreach (var n in navHistory)
            {
                unified.Add((n.NavDate, (double)n.NavValue, false, 0));
            }

            // Transaction points (use TXN NAV)
            foreach (var tx in investmentTxns)
            {
                unified.Add((tx.TransactionDate.Date, (double)tx.NAV, true, (double)tx.AmountPaid));
            }

            // ✅ IMPORTANT: only sort (NO grouping)
            var finalData = unified
                .OrderBy(x => x.date)
                .ToList();

            // =========================
            // 4️⃣ Build chart data
            // =========================

            labels = finalData
                .Select(x => x.date.ToString("dd-MMM-yy"))
                .ToArray();

            navValues = finalData
                .Select(x => x.nav)
                .ToArray();

            // =========================
            // 5️⃣ FULL-LENGTH PURCHASE ARRAY ✅
            // =========================

            purchases = new List<NavLineChart.PurchasePoint>();

            for (int i = 0; i < finalData.Count; i++)
            {
                var row = finalData[i];

                // ✅ default zero (alignment layer)
                purchases.Add(new NavLineChart.PurchasePoint
                {
                    Index = i,
                    Value = 0,
                    Amount = 0
                });

                // ✅ overwrite if txn exists
                if (row.isTxn)
                {
                    purchases[i] = new NavLineChart.PurchasePoint
                    {
                        Index = i,
                        Value = row.nav,       // ✅ correct NAV (txn NAV)
                        Amount = row.amount
                    };
                }
            }
        }
        finally
        {
            isLoading = false;
        }
    }
    
    //* ==============parametrization for binding (if fund id coming from some other page) ============== */
    private int? queryFundId;
    private void ReadQueryParams()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);

        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers
            .ParseQuery(uri.Query)
            .TryGetValue("fundId", out var values))
        {
            if (int.TryParse(values.First(), out var id))
            {
                queryFundId = id;
            }
        }
    }
}