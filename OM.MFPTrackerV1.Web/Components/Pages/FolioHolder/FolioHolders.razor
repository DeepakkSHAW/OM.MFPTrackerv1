@page "/folio-holders"

@using System.ComponentModel.DataAnnotations
@using Microsoft.EntityFrameworkCore
@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services
@using Microsoft.JSInterop

@inject IFolioHolderRepo Repo
@inject IJSRuntime JS

<h4 class="mt-2 mb-3">Folio Holders</h4>

<!-- ============================
     Top Toolbar: Search & Add
     ============================ -->
<div class="row g-2 align-items-end mb-3">
    <div class="col-md-6 col-lg-7">
        <label class="form-label small fw-bold">Search</label>
        <div class="input-group">
            <input class="form-control"
                   @bind="search"
                   @bind:event="oninput"
                   placeholder="Type name or signature..." />

            <button class="btn btn-outline-primary" @onclick="SearchAsync">Search</button>
            <button class="btn btn-outline-secondary" @onclick="ClearAsync">Clear</button>
        </div>
    </div>

    <div class="col text-end">
        <label class="form-label small fw-bold d-block">&nbsp;</label>
        <button class="btn btn-primary" @onclick="OpenAdd">Add Folio Holder</button>
    </div>
</div>

<!-- ============================
     Table
     ============================ -->
<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                @* <th style="width:60px;"><strong class="small">#</strong></th> *@

                <th role="button" title="Number of folios held">
                    <strong class="small">Folios</strong>
                </th>

                <th role="button" @onclick="() => SortBy(nameof(FolioHolder.FirstName))">
                    <strong class="small">First Name</strong>
                    @if (sortBy == nameof(FolioHolder.FirstName))
                    {
                        <span class="ms-1">@((sortDesc ? "▼" : "▲"))</span>
                    }
                </th>

                <th role="button" @onclick="() => SortBy(nameof(FolioHolder.LastName))">
                    <strong class="small">Last Name</strong>
                    @if (sortBy == nameof(FolioHolder.LastName))
                    {
                        <span class="ms-1">@((sortDesc ? "▼" : "▲"))</span>
                    }
                </th>

                <th role="button" @onclick="() => SortBy(nameof(FolioHolder.DateOfBirth))">
                    <strong class="small">Date Of Birth</strong>
                    @if (sortBy == nameof(FolioHolder.DateOfBirth))
                    {
                        <span class="ms-1">@((sortDesc ? "▼" : "▲"))</span>
                    }
                </th>

                <th role="button" @onclick="() => SortBy(nameof(FolioHolder.Signature))">
                    <strong class="small">Signature</strong>
                    @if (sortBy == nameof(FolioHolder.Signature))
                    {
                        <span class="ms-1">@((sortDesc ? "▼" : "▲"))</span>
                    }
                </th>

                <th style="width:160px;"></th>
            </tr>
        </thead>

        <tbody>
            @if (items is null || items.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No records found.</td>
                </tr>
            }
            else
            {
                var startIndex = (pageNumber - 1) * pageSize;

                @foreach (var x in items.Select((it, idx) => new { it, idx }))
                {
                    <tr>
                        @* <td>@(startIndex + x.idx + 1)</td> *@
                        <td>@x.it.Folios.Count</td>
                        <td>@x.it.FirstName</td>
                        <td>@x.it.LastName</td>
                        <td>@x.it.DateOfBirth.ToString("dd-MMM-yyyy")</td>
                        <td>@x.it.Signature</td>

                        <td class="text-end">
                            <button class="btn btn-outline-secondary btn-sm me-2"
                                    @onclick="() => OpenEdit(x.it)">
                                Edit
                            </button>

  @*                           <button class="btn btn-outline-danger btn-sm"
                                    @onclick="() => ConfirmDelete(x.it.FolioHolderId, x.it.FirstName)">
                                Delete
                            </button> *@
                            <button class="btn btn-outline-danger btn-sm"
                                    disabled="@(x.it.Folios.Count > 0)"
                                    title="@(x.it.Folios.Count > 0 ? "Cannot delete holder with existing folios" : null)"
                                    @onclick="() => ConfirmDelete(x.it.FolioHolderId, x.it.FirstName)">
                                Delete
                            </button>

                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- ============================
     Footer: Total + Paging
     ============================ -->
<div class="d-flex align-items-center gap-2">
    <span class="text-muted small">Total: @totalCount</span>

    <div class="ms-auto d-flex align-items-center gap-2">
        <div class="btn-group">
            <button class="btn btn-sm btn-outline-primary" @onclick="FirstPage" disabled="@(pageNumber == 1)">« First</button>
            <button class="btn btn-sm btn-outline-primary" @onclick="PrevPage" disabled="@(pageNumber == 1)">‹ Prev</button>

            <span class="btn btn-sm btn-outline-secondary disabled">Page @pageNumber</span>

            <button class="btn btn-sm btn-outline-primary"
                    @onclick="NextPage"
                    disabled="@((pageNumber * pageSize) >= totalCount)">
                Next ›
            </button>
        </div>

        <div>
            <label class="form-label small fw-bold mb-0 me-1">Page Size</label>
            <select class="form-select form-select-sm d-inline-block" style="width: 90px;" @bind="pageSize">
                <option>5</option>
                <option>10</option>
                <option>20</option>
                <option>50</option>
            </select>
        </div>
    </div>
</div>

<!-- ============================
     Add/Edit Modal (JS-free)
     ============================ -->
@if (showModal)
{
    <div class="modal-backdrop fade show"></div>

    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,.2);">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header py-2" style="background: rgba(200,100,200,.2)">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>

                <div class="modal-body">
                    <EditForm Model="@editModel" OnValidSubmit="@SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                <InputText class="form-control"
                                           @bind-Value="editModel.FirstName"
                                           maxlength="50"
                                           pattern="^[A-Za-z0-9 ]{3,50}$"
                                           title="Letters, numbers, spaces; 3–50 characters" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Last Name</label>
                                <InputText class="form-control"
                                           @bind-Value="editModel.LastName"
                                           maxlength="50"
                                           pattern="^[A-Za-z0-9 ]{3,50}$"
                                           title="Letters, numbers, spaces; 3–50 characters" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Date of Birth</label>
                                <InputDate class="form-control"
                                           @bind-Value="editModel.DateOfBirth" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Signature</label>
                                <InputText class="form-control"
                                           @bind-Value="editModel.Signature"
                                           maxlength="5"
                                           pattern="^[A-Za-z0-9]{2,5}$"
                                           title="Alphanumeric; 2–5 characters" />
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(serverError))
                        {
                            <div class="alert alert-danger py-2 mt-3">
                                @serverError
                            </div>
                        }

                        <div class="text-end mt-3">
                            <button class="btn btn-outline-secondary me-2" type="button" @onclick="CloseModal">Cancel</button>
                            <button class="btn btn-primary" type="submit">Save</button>
                        </div>
                    </EditForm>
                </div>

            </div>
        </div>
    </div>
}

@code {

    private List<FolioHolder> items = new();
    private int totalCount = 0;

    private string? search;
    private string sortBy = nameof(FolioHolder.FirstName);
    private bool sortDesc = false;

    private int pageNumber = 1;

    private int _pageSize = 10;
    private int pageSize
    {
        get => _pageSize;
        set
        {
            if (_pageSize != value)
            {
                _pageSize = value;
                pageNumber = 1;
                _ = Reload();
            }
        }
    }

    // Modal state
    private bool showModal = false;
    private string modalTitle = "Add Folio Holder";
    private EditModel editModel = new();
    private string? serverError;

    protected override async Task OnInitializedAsync()
    {
        await Reload();
    }

    // Reload data
    private async Task Reload()
    {
        var result = await Repo.GetAsync(search, sortBy, sortDesc, pageNumber, pageSize);
        items = result.Items.ToList();
        totalCount = result.TotalCount;
        StateHasChanged();
    }

    // Search / Clear
    private async Task SearchAsync()
    {
        pageNumber = 1;
        await Reload();
    }

    private async Task ClearAsync()
    {
        if (!string.IsNullOrWhiteSpace(search))
        {
            search = string.Empty;
            pageNumber = 1;
            await Reload();
        }
    }

    // Sorting
    private void SortBy(string field)
    {
        if (sortBy == field)
            sortDesc = !sortDesc;
        else
        {
            sortBy = field;
            sortDesc = false;
        }
        _ = Reload();
    }

    // Paging
    private async Task FirstPage()
    {
        if (pageNumber != 1)
        {
            pageNumber = 1;
            await Reload();
        }
    }

    private async Task PrevPage()
    {
        if (pageNumber > 1)
        {
            pageNumber--;
            await Reload();
        }
    }

    private async Task NextPage()
    {
        if ((pageNumber * pageSize) < totalCount)
        {
            pageNumber++;
            await Reload();
        }
    }

    // Modal: Add
    private void OpenAdd()
    {
        serverError = null;
        modalTitle = "Add Folio Holder";

        editModel = new EditModel
        {
            DateOfBirth = DateTime.Today.AddYears(-20)
        };

        showModal = true;
    }

    // Modal: Edit
    private void OpenEdit(FolioHolder x)
    {
        serverError = null;
        modalTitle = "Edit Folio Holder";

        editModel = new EditModel
        {
            FolioHolderId = x.FolioHolderId,
            FirstName = x.FirstName,
            LastName = x.LastName,
            DateOfBirth = x.DateOfBirth,
            Signature = x.Signature
        };

        showModal = true;
    }

    private void CloseModal()
    {
        serverError = null;
        showModal = false;
    }

    // Save (Add or Update)
    private async Task SaveAsync()
    {
        serverError = null;

        var excludeId = editModel.FolioHolderId == 0 ? null : (int?)editModel.FolioHolderId;

        // Signature check
        if (await Repo.ExistsBySignatureAsync(editModel.Signature, excludeId))
        {
            serverError = "Signature must be unique.";
            return;
        }

        // DOB validation
        if (editModel.DateOfBirth >= DateTime.Now)
        {
            serverError = "Date of Birth must be in the past.";
            return;
        }

        try
        {
            if (editModel.FolioHolderId == 0)
            {
                var e = new FolioHolder
                {
                    FirstName = editModel.FirstName.Trim(),
                    LastName = editModel.LastName.Trim(),
                    DateOfBirth = editModel.DateOfBirth,
                    Signature = editModel.Signature.Trim()
                };

                if (await Repo.EnsureUniqueAsync(e, false))
                {
                    serverError = "Folio holder already exists (Name + DOB).";
                    return;
                }

                await Repo.AddAsync(e);
            }
            else
            {
                var e = new FolioHolder
                {
                    FolioHolderId = editModel.FolioHolderId,
                    FirstName = editModel.FirstName.Trim(),
                    LastName = editModel.LastName.Trim(),
                    DateOfBirth = editModel.DateOfBirth,
                    Signature = editModel.Signature.Trim()
                };

                if (await Repo.EnsureUniqueAsync(e, true))
                {
                    serverError = "Folio holder already exists (Name + DOB).";
                    return;
                }

                await Repo.UpdateAsync(e);
            }

            showModal = false;
            await Reload();
        }
        catch (DbUpdateException ex)
        {
            serverError = $"Database error: {ex.GetBaseException().Message}";
        }
        catch (Exception ex)
        {
            serverError = ex.Message;
        }
    }

    // Delete
    private async Task ConfirmDelete(int id, string name)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{name}'?"))
        {
            try
            {
                await Repo.DeleteAsync(id);
                await Reload();
            }
            catch (DbUpdateException ex)
            {
                await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.GetBaseException().Message}");
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", ex.Message);
            }
        }
    }

    // UI EditModel
    public sealed class EditModel
    {
        public int FolioHolderId { get; set; }

        [Required]
        [StringLength(50, MinimumLength = 3)]
        [RegularExpression(@"^[A-Za-z0-9 ]{3,50}$")]
        public string FirstName { get; set; } = string.Empty;

        [Required]
        [StringLength(50, MinimumLength = 3)]
        [RegularExpression(@"^[A-Za-z0-9 ]{3,50}$")]
        public string LastName { get; set; } = string.Empty;

        public DateTime DateOfBirth { get; set; }

        [Required]
        [StringLength(5, MinimumLength = 2)]
        [RegularExpression(@"^[A-Za-z0-9]{2,5}$")]
        public string Signature { get; set; } = string.Empty;
    }
}