@page "/login"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@using OM.MFPTrackerV1.Web.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>Login</PageTitle>

<AuthorizeView>
    <NotAuthorized Context="authState">
        <div class="login-container">
            <div class="card">
                <h3>Sign In</h3>

                @if (HasError)
                {
                    <div class="alert alert-danger">
                        @ErrorMessage
                    </div>
                }

                <EditForm Model="Model" OnValidSubmit="RSLogin">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="form-group">
                        <label>Username</label>
                        <InputText class="form-control" @bind-Value="Model.Username" />
                    </div>

                    <div class="form-group mt-3">
                        <label>Password</label>
                        <InputText type="password" class="form-control" @bind-Value="Model.Password" />
                    </div>

                    <button type="submit" class="btn btn-success w-100">
                        Login
                    </button>
                </EditForm>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 70vh;
    }

    .card {
        width: 100%;
        max-width: 400px;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .alert {
        padding: 0.75rem;
        margin-bottom: 1rem;
        border: 1px solid transparent;
        border-radius: 0.25rem;
        color: #721c24;
        background-color: #f8d7da;
    }
</style>

@code {
    //private LoginRequest Model { get; } = new();
    private LoginRequest Model { get; } = new LoginRequest { Username = "user", Password = "User@123!" };//only for testing, remove default values in production

    private string? ErrorMessage;
    private bool HasError => !string.IsNullOrWhiteSpace(ErrorMessage);


    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "ReturnUrl")]
    public string? ReturnUrlPascal { get; set; }

    private string EffectiveReturnUrl =>
        !string.IsNullOrWhiteSpace(ReturnUrl)
            ? ReturnUrl!
            : !string.IsNullOrWhiteSpace(ReturnUrlPascal)
                ? ReturnUrlPascal!
                : "/";



    private async Task RSLogin()
    {
        ErrorMessage = null;

        var result = await JS.InvokeAsync<LoginResult>(
            "auth.alogin",
            Model.Username,
            Model.Password
        );

        if (!result.Success)
        {
            ErrorMessage = result.Reason switch
            {
                "maintenance" => "Login is temporarily disabled due to maintenance. Please try again later.",
                "invalid" => "Invalid username or password.",
                _ => "An unexpected error occurred. Please try again later."
            };

            return;
        }
        // ✅ success
        //Nav.NavigateTo("/", forceLoad: true);
        Navigation.NavigateTo(string.IsNullOrWhiteSpace(EffectiveReturnUrl) ? "/" : EffectiveReturnUrl);

    }

}