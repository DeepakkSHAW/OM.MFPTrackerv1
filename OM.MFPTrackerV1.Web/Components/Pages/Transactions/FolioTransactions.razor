@page "/folio-transactions"
@page "/folio-transactions/{FolioId:int}"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "User,Admin")]
@using System.ComponentModel.DataAnnotations
@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services

@inject IMutualFundTransactionRepo TxnRepo
@inject IFolioRepo FolioRepo
@inject IMFFundRepo FundRepo
@inject IAMCRepo AmcRepo
@inject NavigationManager Nav
@inject IJSRuntime JS

<!-- ================= TABS ================= -->
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(currentTab == 1 ? "active" : "")"
                @onclick="() => SwitchTab(1)">
            Current
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(currentTab == 2 ? "active" : "")"
                @onclick="() => SwitchTab(2)">
            Time View
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(currentTab == 3 ? "active" : "")"
                @onclick="() => SwitchTab(3)">
            Summary
        </button>
    </li>
</ul>

@if (currentTab == 1)
{
    <h4 class="mt-2 mb-3">Folio Transactions</h4>

    <!-- ================= Toolbar ================= -->
    <div class="row g-2 align-items-end mb-3">

        <div class="col-md-4">
            <label class="form-label small fw-bold">AMC</label>
            <InputSelect TValue="int?"
                         class="form-select"
                         @bind-Value="selectedAmcId"
                         @bind-Value:after="OnAmcChanged">
                <option value="">-- Select AMC --</option>
                @foreach (var a in allAmcs)
                {
                    <option value="@a.AMCId">@a.AMCName</option>
                }
            </InputSelect>
        </div>

        <div class="col-md-4">
            <label class="form-label small fw-bold">Folio</label>
            <InputSelect TValue="int?"
                         class="form-select"
                         disabled="@(!selectedAmcId.HasValue)"
                         @bind-Value="selectedFolioId"
                         @bind-Value:after="OnFolioChanged">
                <option value="">-- Select Folio --</option>
                @foreach (var f in filteredFolios)
                {
                    <option value="@f.FolioId">
                        @f.FolioNumber - @($"{f.Holder.FirstName} {f.Holder.LastName} [{f.AttachedBank}]")
                    </option>
                }
            </InputSelect>
        </div>

        <div class="col-md-4">
            <label class="form-label small fw-bold">Filter Fund</label>
            <select class="form-select"
                    disabled="@(!selectedAmcId.HasValue)"
                    @bind="selectedFundId"
                    @bind:after="ReloadWrapper">
                <option value="">All Funds</option>
                @foreach (var f in filteredFunds)
                {
                    <option value="@f.FundId">@f.FundName</option>
                }
            </select>
        </div>

        <div class="col text-end">
            <label class="form-label small fw-bold d-block">&nbsp;</label>
            <button class="btn btn-primary"
                    @onclick="OpenAdd"
                    @attributes="(selectedFolioId is null ? DisabledAttr : null)">
                Add Transaction
            </button>
        </div>
    </div>
}
else if (currentTab == 2)
{

    <div class="d-flex align-items-center justify-content-between mb-3">

        <h4 class="mb-0">Time View</h4>

        <div class="d-flex align-items-center gap-2">
            <span class="small text-muted">Range:</span>

            <select class="form-select form-select-sm w-auto"
                    @bind="selectedRange"
                    @bind:after="ReloadTimeView">
                @foreach (var r in timeRanges)
                {
                    <option value="@r.Key">@r.Value</option>
                }
            </select>
        </div>
        <button class="btn btn-sm btn-outline-primary"
                title="Open detailed analysis"
                @onclick="GoToAnalysis">
            <i class="bi bi-graph-up"></i>
        </button>
    </div>

    <span class="small text-muted">
        Showing: @timeRanges.First(x => x.Key == selectedRange).Value
    </span>
}
else if (currentTab == 3)
{
    <div class="d-flex align-items-center justify-content-between mb-3 p-2 border-bottom">

        <!-- Left: Title + Context -->
        <div>
            <h4 class="mb-1">Portfolio Summary</h4>
            <div class="text-muted small">
                Across @fundSummary.Count funds
            </div>
        </div>

        <!-- Right: KPI -->
        <div class="text-end">
            <div class="text-muted small">Total Investment</div>
            <div class="fw-bold fs-4 text-primary">
                ₹@totalInvestment.ToString("N0")
            </div>
        </div>

    </div>


    @if (fundSummary.Count == 0)
    {
        <div class="text-muted">No data available.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Fund</th>
                        <th class="text-end">Investment (₹)</th>
                        <th class="text-end">Units</th>
                        <th class="text-end">Avg NAV</th>
                        <th class="text-end">Txns</th>
                        <th class="text-end">Allocation (%)</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var f in fundSummary)
                    {

                        var allocation = totalInvestment == 0 ? 0 : (f.TotalInvestment / totalInvestment) * 100;

                        <tr>
                            <td>@f.FundName</td>
                            <td class="text-end">@f.TotalInvestment.ToString("N0")</td>
                            <td class="text-end">@f.TotalUnits.ToString("0.#####")</td>
                            <td class="text-end">@f.AvgNav.ToString("N2")</td>
                            <td class="text-end">@f.TxnCount</td>
                            <td class="text-end">@allocation.ToString("N1")%</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (selectedFolioId.HasValue && (currentTab == 1 || currentTab == 2))
{
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th role="button" @onclick="@(() => SortBy(nameof(MutualFundTransaction.TransactionDate)))">
                        Date @SortIcon(nameof(MutualFundTransaction.TransactionDate))
                    </th>
                    <th>Fund</th>
                    <th role="button" @onclick="@(() => SortBy(nameof(MutualFundTransaction.TxnType)))">
                        Type @SortIcon(nameof(MutualFundTransaction.TxnType))
                    </th>
                    <th class="text-end">Units</th>
                    <th class="text-end">NAV</th>
                    <th class="text-end">Amount</th>
                    <th style="width:140px"></th>
                </tr>
            </thead>

            <tbody>
                @if (items.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            No transactions found.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var row in items)
                    {
                        <tr>
                            <td>@row.TransactionDate.ToString("dd-MMM-yyyy")</td>
                            <td>@row.Fund.FundName</td>
                            <td>@row.TxnType</td>
                            <td class="text-end">@row.Units.ToString("0.#####")</td>
                            <td class="text-end">@row.NAV.ToString("0.#####")</td>
                            <td class="text-end">@row.AmountPaid.ToString("0.00")</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-secondary me-2"
                                        @onclick="@(() => OpenEdit(row))">
                                    Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="@(() => ConfirmDelete(row.TransactionId))">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Paging -->
    <div class="d-flex align-items-center mt-2 gap-2">
        <span class="text-muted small">Total: @totalCount</span>

        <div class="ms-auto d-flex align-items-center gap-2">
            <button class="btn btn-sm btn-outline-primary"
                    disabled="@(pageNumber == 1)"
                    @onclick="PrevPage">
                ‹
            </button>

            <span class="btn btn-sm btn-outline-secondary disabled">
                Page @pageNumber
            </span>

            <button class="btn btn-sm btn-outline-primary"
                    disabled="@((pageNumber * pageSize) >= totalCount)"
                    @onclick="NextPage">
                ›
            </button>

            <select class="form-select form-select-sm"
                    style="width:90px"
                    @bind="pageSize">
                <option>5</option>
                <option>10</option>
                <option>20</option>
                <option>50</option>
            </select>
        </div>
    </div>
}

<!-- ================= Modal (Add / Edit) ================= -->
@if (showModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header py-2">
                    <h5 class="modal-title">@((isEdit ? "Edit" : "Add") + " Transaction")</h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>

                <div class="modal-body">
                    <EditForm Model="@editModel" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        @if (!string.IsNullOrWhiteSpace(serverError))
                        {
                            <div class="alert alert-danger">
                                @serverError
                            </div>
                        }

                        <div class="row g-3">

                            <div class="col-md-4">
                                <label class="form-label">Date</label>
                                <InputDate class="form-control"
                                           @bind-Value="editModel.TransactionDate" />
                                <ValidationMessage For="@(() => editModel.TransactionDate)" />
                            </div>

                            <div class="col-md-8">
                                <label class="form-label">Fund</label>
                                <InputSelect class="form-select"
                                             disabled="@isEdit"
                                             @bind-Value="editModel.FundId">
                                    <option value="">-- Select Fund --</option>
                                    @foreach (var f in filteredFunds)
                                    {
                                        <option value="@f.FundId">@f.FundName</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => editModel.FundId)" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Transaction Type</label>
                                <InputSelect class="form-select"
                                             disabled="@isEdit"
                                             @bind-Value="editModel.TxnType">
                                    @foreach (var t in Enum.GetValues<TransactionType>())
                                    {
                                        <option value="@t">@t</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Units</label>
                                <InputNumber class="form-control"
                                             step="0.00001"
                                             @bind-Value="editModel.Units"
                                             @bind-Value:after="LimitUnits" />
                                @*  <ValidationMessage For="@(() => editModel.Units)" /> *@
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">NAV</label>
                                <InputNumber class="form-control"
                                             step="0.00001"
                                             @bind-Value="editModel.NAV"
                                             @bind-Value:after="LimitNav" />
                                @*  <ValidationMessage For="@(() => editModel.NAV)" /> *@
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Reference No</label>
                                <InputText class="form-control"
                                           maxlength="50"
                                           @bind-Value="editModel.ReferenceNo" />
                                <ValidationMessage For="@(() => editModel.ReferenceNo)" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Source</label>
                                <InputText class="form-control"
                                           maxlength="50"
                                           @bind-Value="editModel.Source" />
                                <ValidationMessage For="@(() => editModel.Source)" />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label">Note</label>
                                <InputTextArea class="form-control"
                                               rows="2"
                                               maxlength="100"
                                               @bind-Value="editModel.Note" />
                                <ValidationMessage For="@(() => editModel.Note)" />
                            </div>
                        </div>

                        <div class="text-end mt-3">
                            <button type="button"
                                    class="btn btn-outline-secondary me-2"
                                    @onclick="CloseModal">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-primary">
                                Save
                            </button>
                        </div>
                    </EditForm>
                </div>

            </div>
        </div>
    </div>
}

@code {

    /* ================= State ================= */

    [Parameter] public int? FolioId { get; set; }
    /* ================= TAB STATE ================= */
    private int currentTab = 1;
    private string viewMode = "current";

    private List<AMC> allAmcs = new();
    private List<Folio> allFolios = new();
    private List<Fund> allFunds = new();

    private List<Folio> filteredFolios = new();
    private List<Fund> filteredFunds = new();
    private List<MutualFundTransaction> items = new();

    private int? selectedAmcId;
    private int? selectedFolioId;
    private int? selectedFundId;

    private bool showModal;
    private bool isEdit;
    private int editingId;

    private bool _initializedFromRoute;
    private int pageNumber = 1;
    private int pageSize = 10;
    private int totalCount;
    private string sortBy = nameof(MutualFundTransaction.TransactionDate);
    private bool sortDesc = true;
    private string? serverError;
    private EditModel editModel = new();

    private readonly Dictionary<string, object> DisabledAttr =
        new() { { "disabled", "disabled" } };

    /* ================= Life-cycle ================= */
    private async Task SwitchTab(int tab)
    {
        currentTab = tab;
        pageNumber = 1;

        if (tab == 2)
            await ReloadTimeView();
        else if (tab == 1)
            await Reload();
        else if (tab == 3)
            await LoadSummary();

    }
    protected override async Task OnInitializedAsync()
    {
        var amcTask = AmcRepo.GetAsync(null, 0, int.MaxValue);
        var folioTask = FolioRepo.GetAsync(null, null, false, 1, int.MaxValue);
        var fundTask = FundRepo.GetAsync(null, null, false, 1, int.MaxValue);

        await Task.WhenAll(amcTask, folioTask, fundTask);

        allAmcs = amcTask.Result.Items.ToList();
        allFolios = folioTask.Result.Items.ToList();
        allFunds = fundTask.Result.Items.ToList();
    }

    /* ================= Helpers ================= */

    protected override async Task OnParametersSetAsync()
    {
        if (_initializedFromRoute) return;

        if (FolioId.HasValue && allFolios.Any())
        {
            var folio = allFolios.FirstOrDefault(f => f.FolioId == FolioId.Value);

            if (folio != null)
            {
                selectedAmcId = folio.AMCId;
                OnAmcChanged();
                selectedFolioId = folio.FolioId;

                await Reload();

                _initializedFromRoute = true;
            }
        }
    }

    private async Task Reload()
    {
        if (!selectedFolioId.HasValue)
        {
            items.Clear();
            totalCount = 0;
            return;
        }

        var r = await TxnRepo.GetAsync(
            selectedFolioId.Value,
            selectedFundId,
            sortBy,
            sortDesc,
            pageNumber,
            pageSize);

        items = r.Items.ToList();
        totalCount = r.TotalCount;
    }

    private void ReloadWrapper() => _ = Reload();

    private void OpenAdd()
    {
        isEdit = false;
        editingId = 0;

        editModel = new EditModel
        {
            FolioId = selectedFolioId!.Value,
            TransactionDate = DateTime.Today,
            TxnType = TransactionType.BUY
        };

        showModal = true;
    }

    private void OpenEdit(MutualFundTransaction t)
    {
        isEdit = true;
        editingId = t.TransactionId;

        editModel = new EditModel
        {
            FolioId = t.FolioId,
            FundId = t.FundId,
            TransactionDate = t.TransactionDate,
            TxnType = t.TxnType,
            Units = t.Units,
            NAV = t.NAV,
            ReferenceNo = t.ReferenceNo,
            Source = t.Source,
            Note = t.Note
        };

        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveAsync()
    {
        if (isEdit)
        {
            var entity = new MutualFundTransaction
            {
                TransactionId = editingId,
                FolioId = editModel.FolioId,
                FundId = editModel.FundId,
                TransactionDate = editModel.TransactionDate,
                TxnType = editModel.TxnType,
                Units = editModel.Units,
                NAV = editModel.NAV,
                AmountPaid = Math.Round(editModel.Units * editModel.NAV, 5),
                ReferenceNo = editModel.ReferenceNo,
                Source = editModel.Source,
                Note = editModel.Note
            };

            await TxnRepo.UpdateAsync(entity);
        }
        else
        {
            await TxnRepo.AddAsync(editModel.ToEntity());
        }

        showModal = false;
        await Reload();
    }

    private async Task ConfirmDelete(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this transaction permanently?"))
            return;

        await TxnRepo.DeleteAsync(id);
        await Reload();
    }

    private Task OnFolioChanged() => Reload();

    private void OnAmcChanged()
    {
        filteredFolios = allFolios
            .Where(f => f.AMCId == selectedAmcId)
            .OrderBy(f => f.FolioNumber)
            .ToList();

        filteredFunds = allFunds
            .Where(f => f.AMCId == selectedAmcId)
            .OrderBy(f => f.FundName)
            .ToList();

        // ✅ ONLY clear if NOT coming from route
        if (!FolioId.HasValue)
        {
            selectedFolioId = null;
            selectedFundId = null;
        }
    }

    private void OnAmcChanged_DEL()
    {
        filteredFolios = allFolios
            .Where(f => f.AMCId == selectedAmcId)
            .OrderBy(f => f.FolioNumber)
            .ToList();

        filteredFunds = allFunds
            .Where(f => f.AMCId == selectedAmcId)
            .OrderBy(f => f.FundName)
            .ToList();

        selectedFolioId = null;
        selectedFundId = null;
    }

    private void SortBy(string field)
    {
        if (sortBy == field) sortDesc = !sortDesc;
        else { sortBy = field; sortDesc = false; }
        _ = Reload();
    }

    private RenderFragment SortIcon(string f) => b =>
    {
        if (sortBy == f)
            b.AddContent(0, sortDesc ? " ▼" : " ▲");
    };
    private async Task PrevPage()
    {
        if (pageNumber > 1)
        {
            pageNumber--;
            await ReloadByTab();
        }
    }

    private async Task NextPage()
    {
        if ((pageNumber * pageSize) < totalCount)
        {
            pageNumber++;
            await ReloadByTab();
        }
    }
    private async Task ReloadByTab()
    {
        if (currentTab == 2)
            await ReloadTimeView();
        else
            await Reload();
    }

    private void LimitUnits() => editModel.Units = Math.Round(editModel.Units, 5);
    private void LimitNav() => editModel.NAV = Math.Round(editModel.NAV, 5);

    /* ================= Models ================= */

    public sealed class EditModel
    {
        [Required] public int FolioId { get; set; }
        [Required] public int FundId { get; set; }
        [Required] public DateTime TransactionDate { get; set; }
        [Required] public TransactionType TxnType { get; set; }

        [Range(0.000001, double.MaxValue)]
        public decimal Units { get; set; }

        [Range(0.000001, double.MaxValue)]
        public decimal NAV { get; set; }

        [MaxLength(50)] public string? ReferenceNo { get; set; }
        [MaxLength(50)] public string? Source { get; set; }
        [MaxLength(100)] public string? Note { get; set; }

        public MutualFundTransaction ToEntity() => new()
        {
            FolioId = FolioId,
            FundId = FundId,
            TransactionDate = TransactionDate,
            TxnType = TxnType,
            Units = Units,
            NAV = NAV,
            AmountPaid = Math.Round(Units * NAV, 5),
            ReferenceNo = ReferenceNo,
            Source = Source,
            Note = Note
        };
    }

    //********** Code for tab 2 ********//
    private string selectedRange = "1M";

    private List<KeyValuePair<string, string>> timeRanges = new()
    {
        new("1M", "Current Month"),
        new("LM", "Last Month"),
        new("Q", "Last Quarter"),
        new("6M", "Last 6 Months"),
        new("1Y", "Last Year"),
        new("3Y", "Last 3 Years"),
        new("ALL", "Since Inception")
    };

    private (DateTime from, DateTime to) GetDateRange()
    {
        var now = DateTime.Today;

        if (selectedRange == "LM")
        {
            var first = new DateTime(now.Year, now.Month, 1).AddMonths(-1);
            var last = first.AddMonths(1).AddDays(-1);
            return (first, last);
        }

        return selectedRange switch
        {
            "1M" => (new DateTime(now.Year, now.Month, 1), now),
            "Q" => (now.AddMonths(-3), now),
            "6M" => (now.AddMonths(-6), now),
            "1Y" => (now.AddYears(-1), now),
            "3Y" => (now.AddYears(-3), now),
            _ => (DateTime.MinValue, now)
        };
    }
    private async Task ReloadTimeView()
    {
        if (!selectedFolioId.HasValue)
        {
            items.Clear();
            totalCount = 0;
            return;
        }

        // ✅ Step 1: Load all data (no paging)
        var r = await TxnRepo.GetAsync(
            null,
            null,
            sortBy,
            sortDesc,
            1,
            int.MaxValue);

        var allItems = r.Items;

        // ✅ Step 2: Apply date filter
        var (from, to) = GetDateRange();

        var filtered = allItems
            .Where(x => x.TransactionDate >= from && x.TransactionDate <= to);

        // ✅ Step 3: Apply sorting (important!)
        filtered = sortDesc
            ? filtered.OrderByDescending(x => GetSortValue(x))
            : filtered.OrderBy(x => GetSortValue(x));

        // ✅ Step 4: Apply pagination AFTER filtering
        totalCount = filtered.Count();

        items = filtered
            .Skip((pageNumber - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }
    private object GetSortValue(MutualFundTransaction x)
    {
        return sortBy switch
        {
            nameof(MutualFundTransaction.TransactionDate) => x.TransactionDate,
            nameof(MutualFundTransaction.TxnType) => x.TxnType,
            _ => x.TransactionDate
        };
    }
    private void GoToAnalysis()
    {
        //Nav.NavigateTo("/TransactionsOverTime");
        Nav.NavigateTo($"/transactions-over-time?range={selectedRange}");
    }
    //********** Code for tab 3 ********//
   private List<FundSummary> fundSummary = new();
    private decimal totalInvestment;
    private async Task LoadSummary()
    {
        var data = await TxnRepo.GetFundSummaryAsync();

        fundSummary = data
            .Select(x => new FundSummary
            {
                FundName = x.FundName,
                TotalInvestment = x.TotalInvestment,
                TotalUnits = x.TotalUnits,
                AvgNav = x.AvgNav,
                TxnCount = x.TxnCount
            })
            .ToList();

        totalInvestment = fundSummary.Sum(x => x.TotalInvestment);
    }

    private class FundSummary
    {
        public string FundName { get; set; } = "";
        public decimal TotalInvestment { get; set; }
        public decimal TotalUnits { get; set; }
        public decimal AvgNav { get; set; }
        public int TxnCount { get; set; }
    }
}