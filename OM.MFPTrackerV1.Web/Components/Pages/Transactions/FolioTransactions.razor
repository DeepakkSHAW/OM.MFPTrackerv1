@page "/folio-transactions"
@page "/folio-transactions/{FolioId:int}"

@using System.ComponentModel.DataAnnotations
@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services
@inject IMutualFundTransactionRepo TxnRepo
@inject IFolioRepo FolioRepo
@inject IMFFundRepo FundRepo
@inject NavigationManager Nav

<h4 class="mt-2 mb-3">Folio Transactions</h4>

<!-- ================= Toolbar ================= -->
<div class="row g-2 align-items-end mb-3">

    <div class="col-md-4">
        <label class="form-label small fw-bold">Folio</label>
        <InputSelect TValue="int?"
                     class="form-select"
                     @bind-Value="selectedFolioId"
                     @bind-Value:after="FolioChanged">
            <option value="">-- Select Folio --</option>
            @foreach (var f in folios)
            {
                <option value="@f.FolioId">
                    @f.FolioNumber - @($"{f.Holder.FirstName} {f.Holder.LastName}")
                </option>
            }
        </InputSelect>
    </div>

    <div class="col-md-4">
        <label class="form-label small fw-bold">Filter Fund</label>
        <select class="form-select"
                @bind="selectedFundId"
                @bind:after="Reload">
            <option value="">All Funds</option>
            @foreach (var f in funds)
            {
                <option value="@f.FundId">@f.FundName</option>
            }
        </select>
    </div>

    <div class="col text-end">
        <label class="form-label small fw-bold d-block">&nbsp;</label>
        <button class="btn btn-primary"
                @attributes="(selectedFolioId is null ? DisabledAttr : null)"
                title="Select a folio to add transactions"
                @onclick="OpenAdd">
            Add Transaction
        </button>

    </div>
</div>

<!-- ================= Table ================= -->
<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>#</th>

                <th role="button" @onclick="@(() => SortBy(nameof(MutualFundTransaction.TransactionDate)))">
                    Date @SortIcon(nameof(MutualFundTransaction.TransactionDate))
                </th>

                <th>Fund</th>

                <th role="button" @onclick="@(() => SortBy(nameof(MutualFundTransaction.TxnType)))">
                    Type @SortIcon(nameof(MutualFundTransaction.TxnType))
                </th>

                <th class="text-end">Units</th>
                <th class="text-end">NAV</th>
                <th class="text-end">Amount</th>
            </tr>
        </thead>

        <tbody>
            @if (!selectedFolioId.HasValue)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">
                        Select a folio to view transactions.
                    </td>
                </tr>
            }
            else if (items.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">
                        No transactions found.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var x in items.Select((t, i) => new { t, i }))
                {
                    <tr>
                        <td>@(x.i + 1)</td>
                        <td>@x.t.TransactionDate.ToString("dd-MMM-yyyy")</td>
                        <td>@x.t.Fund.FundName</td>
                        <td>@x.t.TxnType</td>
                        <td class="text-end">@x.t.Units</td>
                        <td class="text-end">@x.t.NAV</td>
                        <td class="text-end">@x.t.AmountPaid</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- ================= Paging ================= -->
@if (selectedFolioId.HasValue)
{
    <div class="d-flex align-items-center gap-2 mt-2">
        <span class="text-muted small">Total: @totalCount</span>

        <div class="ms-auto d-flex align-items-center gap-2">
            <div class="btn-group">
                <button class="btn btn-sm btn-outline-primary"
                        disabled="@(pageNumber == 1)"
                        @onclick="FirstPage">
                    «
                </button>

                <button class="btn btn-sm btn-outline-primary"
                        disabled="@(pageNumber == 1)"
                        @onclick="PrevPage">
                    ‹
                </button>

                <span class="btn btn-sm btn-outline-secondary disabled">
                    Page @pageNumber
                </span>

                <button class="btn btn-sm btn-outline-primary"
                        disabled="@((pageNumber * pageSize) >= totalCount)"
                        @onclick="NextPage">
                    ›
                </button>
            </div>

            <select class="form-select form-select-sm"
                    style="width:90px"
                    @bind="pageSize">
                <option>5</option>
                <option>10</option>
                <option>20</option>
                <option>50</option>
            </select>
        </div>
    </div>
}

<!-- ================= Modal ================= -->
@if (showModal)
{
    <div class="modal-backdrop fade show"></div>

    <div class="modal d-block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header py-2">
                    <h5 class="modal-title">Add Transaction</h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>

                <div class="modal-body">
                    <EditForm Model="@editModel" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="row g-3">

                            <div class="col-md-4">
                                <label class="form-label">Date</label>
                                <InputDate class="form-control"
                                           @bind-Value="editModel.TransactionDate" />
                            </div>

                            <div class="col-md-8">
                                <label class="form-label">Fund</label>
                                <InputSelect class="form-select"
                                             @bind-Value="editModel.FundId"
                                             @bind-Value:after="UpdateAvailableUnits">
                                    <option value="">-- Select Fund --</option>
                                    @foreach (var f in funds)
                                    {
                                        <option value="@f.FundId">@f.FundName</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Transaction Type</label>
                                <InputSelect class="form-select"
                                             @bind-Value="editModel.TxnType"
                                             @bind-Value:after="UpdateAvailableUnits">
                                    @foreach (var t in Enum.GetValues<TransactionType>())
                                    {
                                        <option value="@t">@t</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Units</label>
                                <InputNumber class="form-control" step="0.000001"
                                             @bind-Value="editModel.Units" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">NAV</label>
                                <InputNumber class="form-control" step="0.0001"
                                             @bind-Value="editModel.NAV" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Reference No</label>
                                <InputText class="form-control"
                                           @bind-Value="editModel.ReferenceNo" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Source</label>
                                <InputText class="form-control"
                                           @bind-Value="editModel.Source" />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label">Note</label>
                                <InputTextArea class="form-control" rows="2"
                                               @bind-Value="editModel.Note" />
                            </div>
                        </div>

                        @if (showAvailableUnits)
                        {
                            <div class="alert alert-info mt-3">
                                Available Units: <strong>@availableUnits</strong>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(serverError))
                        {
                            <div class="alert alert-danger mt-2">
                                @serverError
                            </div>
                        }

                        <div class="text-end mt-3">
                            <button type="button"
                                    class="btn btn-outline-secondary me-2"
                                    @onclick="CloseModal">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-primary">
                                Save
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {

    [Parameter] public int? FolioId { get; set; }

    private List<Folio> folios = new();
    private List<Fund> funds = new();
    private List<MutualFundTransaction> items = new();

    private int? selectedFolioId;
    private int? selectedFundId;

    private int totalCount;
    private string sortBy = nameof(MutualFundTransaction.TransactionDate);
    private bool sortDesc = true;
    private int pageNumber = 1;

    private int _pageSize = 10;
    private int pageSize
    {
        get => _pageSize;
        set { _pageSize = value; pageNumber = 1; _ = Reload(); }
    }

    private bool showModal;
    private decimal availableUnits;
    private bool showAvailableUnits;
    private string? serverError;

    private EditModel editModel = new();

    protected override async Task OnInitializedAsync()
    {
        folios = (await FolioRepo.GetAsync(null, null, false, 1, 500)).Items.ToList();
        funds = (await FundRepo.GetAsync(null, null, false, 1, 500)).Items.ToList();

        if (FolioId.HasValue)
            selectedFolioId = FolioId.Value;

        await Reload();
    }

    private async Task Reload()
    {
        if (!selectedFolioId.HasValue)
        {
            items.Clear();
            totalCount = 0;
            return;
        }

        var r = await TxnRepo.GetAsync(
            selectedFolioId.Value,
            selectedFundId,
            sortBy,
            sortDesc,
            pageNumber,
            pageSize);

        items = r.Items.ToList();
        totalCount = r.TotalCount;
    }


    private readonly Dictionary<string, object> DisabledAttr = new() { { "disabled", "disabled" } };

    private async Task FolioChanged()
    {
        pageNumber = 1;

        if (selectedFolioId.HasValue)
        {
            await Reload();  // ✅ THIS WAS MISSING
            Nav.NavigateTo($"/folio-transactions/{selectedFolioId.Value}", replace: true);
        }
        else
        {
            items.Clear();
            totalCount = 0;
        }
    }

    private void SortBy(string field)
    {
        if (sortBy == field) sortDesc = !sortDesc;
        else { sortBy = field; sortDesc = false; }
        _ = Reload();
    }

    private RenderFragment SortIcon(string f) => b =>
    {
        if (sortBy == f) b.AddContent(0, sortDesc ? " ▼" : " ▲");
    };

    private async Task FirstPage() { pageNumber = 1; await Reload(); }
    private async Task PrevPage() { if (pageNumber > 1) { pageNumber--; await Reload(); } }
    private async Task NextPage()
    {
        if ((pageNumber * pageSize) < totalCount)
        {
            pageNumber++;
            await Reload();
        }
    }

    private void OpenAdd()
    {
        editModel = new EditModel
        {
            FolioId = selectedFolioId!.Value,
            TransactionDate = DateTime.Today,
            TxnType = TransactionType.BUY
        };
        showModal = true;
        serverError = null;
        showAvailableUnits = false;
    }

    private void CloseModal() => showModal = false;

    private async Task UpdateAvailableUnits()
    {
        showAvailableUnits = false;

        if (editModel.FundId == 0)
            return;

        if (editModel.TxnType is TransactionType.SELL or TransactionType.SWITCH_OUT)
        {
            availableUnits = await TxnRepo
                .GetAvailableUnitsAsync(editModel.FolioId, editModel.FundId);

            showAvailableUnits = true;
        }
    }

    private async Task SaveAsync()
    {
        serverError = null;

        try
        {
            await TxnRepo.AddAsync(editModel.ToEntity());
            showModal = false;
            await Reload();
        }
        catch (Exception ex)
        {
            serverError = ex.Message;
        }
    }

    public sealed class EditModel
    {
        public int FolioId { get; set; }

        [Required] public int FundId { get; set; }
        [Required] public DateTime TransactionDate { get; set; }
        [Required] public TransactionType TxnType { get; set; }

        public decimal Units { get; set; }
        public decimal NAV { get; set; }

        public string? ReferenceNo { get; set; }
        public string? Source { get; set; }
        public string? Note { get; set; }

        public MutualFundTransaction ToEntity() => new()
        {
            FolioId = FolioId,
            FundId = FundId,
            TransactionDate = TransactionDate,
            TxnType = TxnType,
            Units = Units,
            NAV = NAV,
            ReferenceNo = ReferenceNo,
            Source = Source,
            Note = Note
        };
    }
}