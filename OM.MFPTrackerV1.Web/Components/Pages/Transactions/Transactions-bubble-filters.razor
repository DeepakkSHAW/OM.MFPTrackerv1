    /* ===========================
       DATE FILTERS
       =========================== */
    private DateTime? StartDate = DateTime.Today.AddMonths(-1);
    private DateTime? EndDate = DateTime.Today;

    /* ===========================
       MASTER DATA
       =========================== */
    private List<MFCategory> Categories = new();
    private List<AMC> AllAMCs = new();
    private List<Fund> AllFunds = new();
    private List<Folio> AllFolios = new();

    /* ===========================
       FILTERED DATA
       =========================== */
    private List<AMC> FilteredAMCs = new();
    private List<Fund> FilteredFunds = new();
    private List<Folio> FilteredFolios = new();
    private List<FolioHolder> FilteredHolders = new();

    /* ===========================
       SELECTION BACKING FIELDS
       (Setters handle cascade logic)
       =========================== */

    private int? _selectedCategoryId;
    private int? SelectedCategoryId
    {
        get => _selectedCategoryId;
        set
        {
            _selectedCategoryId = value;

            // Reset downstream
            SelectedAmcId = null;
            SelectedFundId = null;
            SelectedFolioId = null;
            SelectedHolderId = null;

            ApplyFilters();
        }
    }

    private int? _selectedAmcId;
    private int? SelectedAmcId
    {
        get => _selectedAmcId;
        set
        {
            _selectedAmcId = value;

            SelectedFundId = null;
            SelectedFolioId = null;
            SelectedHolderId = null;

            ApplyFilters();
        }
    }

    private int? _selectedFundId;
    private int? SelectedFundId
    {
        get => _selectedFundId;
        set
        {
            _selectedFundId = value;

            SelectedFolioId = null;
            SelectedHolderId = null;

            ApplyFilters();
        }
    }

    private int? _selectedFolioId;
    private int? SelectedFolioId
    {
        get => _selectedFolioId;
        set
        {
            _selectedFolioId = value;
            SelectedHolderId = null;

            _ = LoadHoldersAsync();
        }
    }

    private int? SelectedHolderId;

    /* ===========================
       INITIAL LOAD
       =========================== */
    protected override async Task OnInitializedAsync()
    {
        Categories = (await CategoryRepo.GetAllAsync()).ToList();
        AllAMCs = (await AMCRepo.GetAllAsync()).ToList();
        AllFunds = (await FundRepo.GetAllAsync()).ToList();
        AllFolios = (await FolioRepo.GetAllAsync()).ToList();

        ApplyFilters();
    }

    /* ===========================
       FILTER APPLICATION
       =========================== */
    private void ApplyFilters()
    {
        // Filter AMC by category through funds
        FilteredAMCs = AllAMCs
            .Where(a =>
                !_selectedCategoryId.HasValue ||
                AllFunds.Any(f =>
                    f.AMCId == a.AMCId &&
                    f.MFCatId == _selectedCategoryId))
            .ToList();

        // Filter funds
        FilteredFunds = AllFunds
            .Where(f =>
                (!_selectedCategoryId.HasValue || f.MFCatId == _selectedCategoryId) &&
                (!_selectedAmcId.HasValue || f.AMCId == _selectedAmcId))
            .ToList();

        // Filter folios (folio belongs to AMC)
        FilteredFolios = AllFolios
            .Where(f =>
                !_selectedAmcId.HasValue || f.AMCId == _selectedAmcId)
            .ToList();

        FilteredHolders.Clear();
    }

    /* ===========================
       HOLDER LOAD (FROM TRANSACTIONS)
       =========================== */
    private async Task LoadHoldersAsync()
    {
        if (!_selectedFolioId.HasValue)
        {
            FilteredHolders.Clear();
            return;
        }

        FilteredHolders =
            await TxnRepo.GetHoldersForTransactionsAsync(
                _selectedFolioId,
                _selectedFundId,
                _selectedAmcId,
                _selectedCategoryId);
    }

    private TransactionFilter BuildFilter()
    {
        return new TransactionFilter
        {
            StartDate = StartDate,
            EndDate = EndDate,

            CategoryId = SelectedCategoryId,
            AMCId = SelectedAmcId,
            FundId = SelectedFundId,
            FolioId = SelectedFolioId,
            HolderId = SelectedHolderId
        };
    }
    private async Task ExportToCsv()
    {
        if (BubbleData.Count == 0)
            return;

        var sb = new StringBuilder();

        // CSV header
        sb.AppendLine("Date,Fund,Holder,NAV,Investment");

        foreach (var item in BubbleData)
        {
            sb.AppendLine(
                $"{item.X:yyyy-MM-dd}," +
                $"\"{item.Fund}\"," +
                $"\"{item.Holder}\"," +
                $"{item.Y}," +
                $"{item.Investment}");
        }

        var bytes = Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);

        await JS.InvokeVoidAsync(
            "downloadFile",
            $"transactions-{DateTime.Today:yyyyMMdd}.csv",
            base64);
    }

}