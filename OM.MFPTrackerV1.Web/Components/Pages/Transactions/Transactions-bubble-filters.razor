<!-- ===========================
     ACTION BAR
     =========================== -->
<div class="d-flex align-items-center gap-2 mb-3">

    <button class="btn btn-primary" @onclick="LoadBubbles">
        Apply Filters
    </button>

    <button class="btn btn-outline-secondary"
            disabled="@(BubbleData.Count == 0)"
            @onclick="() => ShowTable = !ShowTable">
        @(ShowTable ? "View as Chart" : "View as Table")
    </button>

    @if (ShowTable && BubbleData.Count > 0)
    {
        <button class="btn btn-outline-success ms-1"
                @onclick="ExportToCsv">
            Export CSV
        </button>
    }

    <!-- ✅ Summary aligned to the right -->
    <div class="ms-auto text-muted small">
        @if (BubbleData.Count > 0)
        {
            <span>
                <strong>Total Investment:</strong>
                ₹@TotalInvestment.ToString("N0")
            </span>
        }
    </div>
</div>

<!-- ===========================
     CONTENT AREA
     =========================== -->
@if (BubbleData.Count == 0)
{
    <div class="text-muted text-center mt-5">
        No transactions found for the selected filters.
    </div>
}
else if (!ShowTable)
{
    <!-- ✅ CHART VIEW -->
    <div style="height: calc(100vh - 260px);">
        <BubbleChart Data="@BubbleData" />
    </div>
}
else
{
    <!-- ✅ TABLE VIEW -->
    <!-- Header + Export button -->
    <div class="d-flex align-items-center justify-content-between mb-2">
        <h6 class="mb-0">Transactions – Tabular View</h6>

        <button class="btn btn-sm btn-outline-success"
                @onclick="ExportToCsv">
            Export CSV
        </button>
    </div>

    <!-- Table -->
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Fund</th>
                    <th>Holder</th>
                    <th class="text-end">NAV</th>
                    <th class="text-end">Investment (₹)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in BubbleData.OrderBy(b => b.X))
                {
                    <tr>
                        <td>@item.X.ToString("dd-MMM-yyyy")</td>
                        <td>@item.Fund</td>
                        <td>@item.Holder</td>
                        <td class="text-end">@item.Y.ToString("N2")</td>
                        <td class="text-end">@item.Investment.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

