@page "/transactions-bubble-filters"
@rendermode InteractiveServer

@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services
@using OM.MFPTrackerV1.Web.Components
@using OM.MFPTrackerV1.Web.Models.ViewModels
@using System.Text

@inject IJSRuntime JS
@inject IMFCategoryRepo CategoryRepo
@inject IAMCRepo AMCRepo
@inject IMFFundRepo FundRepo
@inject IFolioRepo FolioRepo
@inject IMutualFundTransactionRepo TxnRepo

<h4 class="mb-3">MF Transaction Filters (Validation Page)</h4>

<!-- ===========================
     FILTER PANEL
     =========================== -->
<div class="card">
    <div class="card-body">
        <div class="row g-3">

            <!-- Start Date -->
            <div class="col-md-3">
                <label class="form-label">Start Date</label>
                <InputDate class="form-control" @bind-Value="StartDate" />
            </div>

            <!-- End Date -->
            <div class="col-md-3">
                <label class="form-label">End Date</label>
                <InputDate class="form-control" @bind-Value="EndDate" />
            </div>

            <!-- CATEGORY -->
            <div class="col-md-3">
                <label class="form-label">MF Category</label>
                <InputSelect class="form-select" @bind-Value="SelectedCategoryId">
                    <option value="">All</option>
                    @foreach (var c in Categories)
                    {
                        <option value="@c.MFCatId">@c.CategoryName</option>
                    }
                </InputSelect>
            </div>

            <!-- AMC -->
            <div class="col-md-3">
                <label class="form-label">AMC</label>
                <InputSelect class="form-select" @bind-Value="SelectedAmcId">
                    <option value="">All</option>
                    @foreach (var a in FilteredAMCs)
                    {
                        <option value="@a.AMCId">@a.AMCName</option>
                    }
                </InputSelect>
            </div>

            <!-- FUND -->
            <div class="col-md-4">
                <label class="form-label">Fund</label>
                <InputSelect class="form-select" @bind-Value="SelectedFundId">
                    <option value="">All</option>
                    @foreach (var f in FilteredFunds)
                    {
                        <option value="@f.FundId">@f.FundName</option>
                    }
                </InputSelect>
            </div>

            <!-- FOLIO -->
            <div class="col-md-4">
                <label class="form-label">Folio</label>
                <InputSelect class="form-select" @bind-Value="SelectedFolioId">
                    <option value="">All</option>
                    @foreach (var f in FilteredFolios)
                    {
                        <option value="@f.FolioId">@f.FolioNumber</option>
                    }
                </InputSelect>
            </div>

            <!-- HOLDER -->
            <div class="col-md-4">
                <label class="form-label">Holder</label>
                <InputSelect class="form-select"
                             @bind-Value="SelectedHolderId"
                             disabled="@(!FilteredHolders.Any())">
                    <option value="">All</option>
                    @foreach (var h in FilteredHolders)
                    {
                        <option value="@h.FolioHolderId">
                            @($"{h.FirstName} {h.LastName}")
                        </option>
                    }
                </InputSelect>
            </div>

        </div>
    </div>
</div>

<!-- ===========================
     DEBUG OUTPUT (IMPORTANT)
     =========================== -->
