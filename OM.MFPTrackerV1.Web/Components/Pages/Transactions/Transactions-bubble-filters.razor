@code {
    private bool ShowTable = false;
    private List<BubbleChartPoint> BubbleData = new();
    private decimal TotalInvestment => BubbleData.Sum(x => x.Investment);
    private async Task LoadBubbles()
    {
        // ✅ Clear holder selection if it no longer applies
        if (!FilteredHolders.Any())
            SelectedHolderId = null;

        var raw = await TxnRepo.GetBubbleDataAsync(BuildFilter());

        BubbleData = raw
            .Select(x => new BubbleChartPoint
            {
                X = x.Date,                    // DateTime is correct
                Y = x.Nav,                     // NAV
                Investment = x.TotalInvestment,
                Fund = x.FundName,
                Holder = x.HolderName,
                ColorKey = HashCode.Combine(x.FundId, x.HolderId)
            })
            .ToList();

        StateHasChanged();
    }
