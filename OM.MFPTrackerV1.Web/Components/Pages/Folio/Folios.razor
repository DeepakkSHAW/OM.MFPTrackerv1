@page "/mf-folios"

@using System.ComponentModel.DataAnnotations
@using Microsoft.EntityFrameworkCore
@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services
@using Microsoft.JSInterop

@inject IFolioRepo Repo
@inject IAMCRepo AMCRepo
@inject IFolioHolderRepo HolderRepo
@inject IJSRuntime JS
@inject NavigationManager Nav

<h4 class="mt-2 mb-3">Folios</h4>

<!-- ===========================
     Top Toolbar
     =========================== -->
<div class="row g-2 align-items-end mb-3">
    <div class="col-md-6 col-lg-7">
        <label class="form-label small fw-bold">Search</label>
        <div class="input-group">
            <input class="form-control"
                   @bind="search"
                   @bind:event="oninput"
                   placeholder="Folio No / Holder / AMC" />

            <button class="btn btn-outline-primary" @onclick="SearchAsync">Search</button>
            <button class="btn btn-outline-secondary" @onclick="ClearAsync">Clear</button>
        </div>
    </div>

    <div class="col text-end">
        <label class="form-label small fw-bold d-block">&nbsp;</label>
        <button class="btn btn-primary" @onclick="OpenAdd">Add Folio</button>
    </div>
</div>

<!-- ===========================
     Table
     =========================== -->
<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th style="width:60px;"><strong class="small">#</strong></th>

                <th role="button" @onclick="@(() => SortBy(nameof(Folio.FolioNumber)))">
                    <strong class="small">Folio No</strong>@SortIcon(nameof(Folio.FolioNumber))
                </th>

                <th role="button" @onclick="@(() => SortBy("AMC"))">
                    <strong class="small">AMC</strong>@SortIcon("AMC")
                </th>

                <th role="button" @onclick="@(() => SortBy("Holder"))">
                    <strong class="small">Holder</strong>@SortIcon("Holder")
                </th>

                <th class="text-center">
                    <strong class="small">Active</strong>
                </th>

                <th style="width:160px;"></th>
            </tr>
        </thead>

        <tbody>
            @if (items.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No records found.</td>
                </tr>
            }
            else
            {
                @foreach (var x in items.Select((it, idx) => new { it, idx }))
                {
                    <tr>
                        <td>@(x.idx + 1)</td>
                        <td>@x.it.FolioNumber</td>
                        <td>@x.it.AMC?.AMCName</td>
                        <td>@($"{x.it.Holder?.FirstName} {x.it.Holder?.LastName}")</td>
                        <td class="text-center">
                            @(x.it.IsActive ? "Yes" : "No")
                        </td>
@*                         <td class="text-end">
                            <button class="btn btn-outline-secondary btn-sm me-2"
                                    @onclick="@(() => OpenEdit(x.it))">
                                Edit
                            </button>

                            <button class="btn btn-outline-danger btn-sm"
                                    @onclick="@(() => ConfirmDelete(x.it.FolioId, x.it.FolioNumber))">
                                Delete
                            </button>
                        </td> *@
                        <td class="text-end">
                            <button class="btn btn-outline-primary btn-sm me-2"
                                    @onclick="@(() => ViewTransactions(x.it.FolioId))">
                                Transactions
                            </button>

                            <button class="btn btn-outline-secondary btn-sm me-2"
                                    @onclick="@(() => OpenEdit(x.it))">
                                Edit
                            </button>

                            <button class="btn btn-outline-danger btn-sm"
                                    @onclick="@(() => ConfirmDelete(x.it.FolioId, x.it.FolioNumber))">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- ===========================
     Footer
     =========================== -->
<div class="d-flex align-items-center gap-2">
    <span class="text-muted small">Total: @totalCount</span>

    <div class="ms-auto d-flex align-items-center gap-2">
        <div class="btn-group">
            <button class="btn btn-sm btn-outline-primary" disabled="@(pageNumber == 1)"
                    @onclick="FirstPage">
                «
            </button>
            <button class="btn btn-sm btn-outline-primary" disabled="@(pageNumber == 1)"
                    @onclick="PrevPage">
                ‹
            </button>
            <span class="btn btn-sm btn-outline-secondary disabled">Page @pageNumber</span>
            <button class="btn btn-sm btn-outline-primary"
                    disabled="@((pageNumber * pageSize) >= totalCount)"
                    @onclick="NextPage">
                ›
            </button>
        </div>

        <select class="form-select form-select-sm" style="width:90px;" @bind="pageSize">
            <option>5</option>
            <option>10</option>
            <option>20</option>
            <option>50</option>
        </select>
    </div>
</div>

<!-- ===========================
     Modal
     =========================== -->
@if (showModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,.2);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>

                <div class="modal-body">
                    <EditForm Model="@editModel" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-2">
                            <label class="form-label">Folio Number</label>
                            <InputText maxlength="50" class="form-control" @bind-Value="editModel.FolioNumber" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">AMC</label>
                            <InputSelect class="form-select" @bind-Value="editModel.AMCId">
                                <option value="">-- Select --</option>
                                @foreach (var a in amcs)
                                {
                                    <option value="@a.AMCId">@a.AMCName</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Holder</label>
                            <InputSelect class="form-select" @bind-Value="editModel.FolioHolderId">
                                <option value="">-- Select --</option>
                                @foreach (var h in holders)
                                {
                                    <option value="@h.FolioHolderId">@($"{h.FirstName} {h.LastName}")</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Purpose</label>
                            <InputText maxlength="100" class="form-control" @bind-Value="editModel.FolioPurpose" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Attached Bank</label>
                            <InputText maxlength="50" class="form-control" @bind-Value="editModel.AttachedBank" />
                        </div>

                        <div class="form-check mb-2">
                            <InputCheckbox class="form-check-input" @bind-Value="editModel.IsActive" />
                            <label class="form-check-label">Active</label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(serverError))
                        {
                            <div class="alert alert-danger">@serverError</div>
                        }

                        <div class="text-end">
                            <button type="button" class="btn btn-outline-secondary me-2" @onclick="CloseModal">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {

    private List<Folio> items = new();
    private List<AMC> amcs = new();
    private List<FolioHolder> holders = new();

    private int totalCount;
    private string? search;
    private string sortBy = nameof(Folio.FolioNumber);
    private bool sortDesc;
    private int pageNumber = 1;

    private int _pageSize = 10;
    private int pageSize
    {
        get => _pageSize;
        set { _pageSize = value; pageNumber = 1; _ = Reload(); }
    }

    private bool showModal;
    private string modalTitle = "";
    private string? serverError;
    private EditModel editModel = new();

    protected override async Task OnInitializedAsync()
    {
        amcs = (await AMCRepo.GetAllAsync()).ToList();
        holders = (await HolderRepo.GetAsync(null, null, false, 1, 500)).Items.ToList();
        await Reload();
    }

    private async Task Reload()
    {
        var r = await Repo.GetAsync(search, sortBy, sortDesc, pageNumber, pageSize);
        items = r.Items.ToList();
        totalCount = r.TotalCount;
    }

    private void SortBy(string field)
    {
        if (sortBy == field) sortDesc = !sortDesc;
        else { sortBy = field; sortDesc = false; }
        _ = Reload();
    }

    private RenderFragment SortIcon(string f) => builder =>
    {
        if (sortBy == f) builder.AddContent(0, sortDesc ? " ▼" : " ▲");
    };

    private async Task SearchAsync() { pageNumber = 1; await Reload(); }
    private async Task ClearAsync() { search = ""; pageNumber = 1; await Reload(); }
    private async Task FirstPage() { pageNumber = 1; await Reload(); }
    private async Task PrevPage() { if (pageNumber > 1) { pageNumber--; await Reload(); } }
    private async Task NextPage() { if (pageNumber * pageSize < totalCount) { pageNumber++; await Reload(); } }

    private void OpenAdd()
    {
        editModel = new();
        modalTitle = "Add Folio";
        showModal = true;
        serverError = null;
    }

    private void OpenEdit(Folio f)
    {
        editModel = new EditModel
        {
            FolioId = f.FolioId,
            FolioNumber = f.FolioNumber,
            AMCId = f.AMCId,
            FolioHolderId = f.FolioHolderId,
            FolioPurpose = f.FolioPurpose,
            AttachedBank = f.AttachedBank,
            IsActive = f.IsActive
        };
        modalTitle = "Edit Folio";
        showModal = true;
        serverError = null;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveAsync()
    {
        serverError = null;

        var excludeId = editModel.FolioId == 0 ? (int?)null : editModel.FolioId;

        if (await Repo.ExistsByFolioNumberAsync(
            editModel.FolioNumber, editModel.AMCId, excludeId))
        {
            serverError = "Folio number already exists for selected AMC.";
            return;
        }

        try
        {
            if (editModel.FolioId == 0)
                await Repo.AddAsync(editModel.ToEntity());
            else
                await Repo.UpdateAsync(editModel.ToEntity());

            showModal = false;
            await Reload();
        }
        catch (Exception ex)
        {
            serverError = ex.GetBaseException().Message;
        }
    }

    private async Task ConfirmDelete(int id, string fno)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Delete folio '{fno}'?"))
        {
            await Repo.DeleteAsync(id);
            await Reload();
        }
    }

    public sealed class EditModel
    {
        public int FolioId { get; set; }

        [Required, StringLength(50, MinimumLength = 5)]
        public string FolioNumber { get; set; } = "";

        [Required] public int AMCId { get; set; }
        [Required] public int FolioHolderId { get; set; }

        public string? FolioPurpose { get; set; }
        public string? AttachedBank { get; set; }
        public bool IsActive { get; set; } = true;

        public Folio ToEntity() => new()
        {
            FolioId = FolioId,
            FolioNumber = FolioNumber.Trim(),
            AMCId = AMCId,
            FolioHolderId = FolioHolderId,
            FolioPurpose = FolioPurpose,
            AttachedBank = AttachedBank,
            IsActive = IsActive
        };
    }
    private void ViewTransactions(int folioId)
    {
        Nav.NavigateTo($"/folio-transactions/{folioId}");
    }
}