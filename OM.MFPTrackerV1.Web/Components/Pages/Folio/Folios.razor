@page "/mf-folios"
@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore

@inject IFolioRepo FolioRepo
@inject IFolioHolderRepo HolderRepo
@inject IFundRepo FundRepo
@inject IJSRuntime JS

<h3>Folios</h3>

<div class="d-flex gap-2 mb-3">
    <button class="btn btn-sm btn-success" @onclick="OpenAdd">Add Folio</button>
</div>

<!-- Filters (2-row clean layout) -->
<div class="card mb-3">
    <div class="card-body">

        <!-- Row 1 -->
        <div class="row g-2 mb-2">
            <div class="col-md-3">
                <label class="form-label mb-0 small fw-semibold">Folio number</label>
                <input class="form-control form-control-sm" @bind="filterFolio" placeholder="e.g., 1234/56" />
            </div>
            <div class="col-md-3">
                <label class="form-label mb-0 small fw-semibold">Holder name</label>
                <input class="form-control form-control-sm" @bind="filterHolder" placeholder="First or Last" />
            </div>
            <div class="col-md-3">
                <label class="form-label mb-0 small fw-semibold">Fund name</label>
                <input class="form-control form-control-sm" @bind="filterFund" placeholder="e.g., Small Cap" />
            </div>
            <div class="col-md-3 d-flex align-items-center">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="activeOnly" @bind="filterActiveOnly" />
                    <label class="form-check-label small" for="activeOnly">Only Active</label>
                </div>
            </div>
        </div>

        <!-- Row 2 -->
        <div class="row g-2 align-items-end">
            <div class="col-md-6"></div>
            <div class="col-md-6 d-flex justify-content-end gap-2">
                <button class="btn btn-sm btn-primary" @onclick="ApplyFilters">Search</button>
                <button class="btn btn-sm btn-secondary" @onclick="ClearFilters">Clear</button>
            </div>
        </div>

    </div>
</div>

<table class="table table-sm table-striped align-middle">
    <thead class="table-head-sm-bold">
        <tr>
            <th aria-sort="@AriaSort("FolioNumber")">
                <div class="th-sort d-flex align-items-center" role="button" title="Sort by Folio" @onclick='() => Sort("FolioNumber")'>
                    <span class="th-title">Folio</span>
                    <span class="th-caret">@((MarkupString)SortGlyph("FolioNumber").Value)</span>
                </div>
            </th>
            <th aria-sort="@AriaSort("Holder")">
                <div class="th-sort d-flex align-items-center" role="button" title="Sort by Holder" @onclick='() => Sort("Holder")'>
                    <span class="th-title">Holder</span>
                    <span class="th-caret">@((MarkupString)SortGlyph("Holder").Value)</span>
                </div>
            </th>
            <th aria-sort="@AriaSort("Fund")">
                <div class="th-sort d-flex align-items-center" role="button" title="Sort by Fund" @onclick='() => Sort("Fund")'>
                    <span class="th-title">Fund</span>
                    <span class="th-caret">@((MarkupString)SortGlyph("Fund").Value)</span>
                </div>
            </th>
            <th aria-sort="@AriaSort("Bank")" style="width:180px;">
                <div class="th-sort d-flex align-items-center" role="button" title="Sort by Bank" @onclick='() => Sort("Bank")'>
                    <span class="th-title">Bank</span>
                    <span class="th-caret">@((MarkupString)SortGlyph("Bank").Value)</span>
                </div>
            </th>
            <th aria-sort="@AriaSort("Active")" style="width:120px;">
                <div class="th-sort d-flex align-items-center" role="button" title="Sort by Active" @onclick='() => Sort("Active")'>
                    <span class="th-title">Active</span>
                    <span class="th-caret">@((MarkupString)SortGlyph("Active").Value)</span>
                </div>
            </th>
            <th style="width:160px;"></th>
        </tr>
    </thead>
    <tbody>
        @if (_items is null)
        {
            <tr><td colspan="6">Loading...</td></tr>
        }
        else if (_items.Count == 0)
        {
            <tr><td colspan="6">No data</td></tr>
        }
        else
        {
            @foreach (var x in _items)
            {
                var holder = x.Holder is null ? "-" : $"{x.Holder.FirstName} {x.Holder.LastName}";
                <tr>
                    <td>@x.FolioNumber</td>
                    <td>@holder</td>
                    <td>@x.Fund?.FundName</td>
                    <td>@x.AttachedBank</td>
                    <td>
                        <span class="badge bg-@(x.IsActive ? "success" : "secondary")">@((x.IsActive ? "Yes" : "No"))</span>
                    </td>
                    <td class="text-end">
                        <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => OpenEdit(x)">Edit</button>
                        <button class="btn btn-outline-danger btn-sm"
                                @onclick='() => ConfirmDelete(x.FolioId, $"{x.FolioNumber}")'>
                            Delete
                        </button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<!-- Pagination -->
<div class="d-flex align-items-center justify-content-between">
    <div>Showing @FromRow–@ToRow of @totalCount</div>
    <div class="d-flex align-items-center gap-2">
        <div class="input-group input-group-sm" style="width:auto;">
            <span class="input-group-text">Page size</span>
            <select class="form-select form-select-sm" style="width:auto" @bind="PageSize">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(pageNumber == 1 ? "disabled" : null)">
                    <button class="page-link" @onclick="FirstPage">«</button>
                </li>
                <li class="page-item @(pageNumber == 1 ? "disabled" : null)">
                    <button class="page-link" @onclick="PrevPage">‹</button>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @pageNumber of @totalPages</span>
                </li>
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : null)">
                    <button class="page-link" @onclick="NextPage">›</button>
                </li>
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : null)">
                    <button class="page-link" @onclick="LastPage">»</button>
                </li>
            </ul>
        </nav>
    </div>
</div>

@* ---------------- Modal (JS-free; Add & Edit) ---------------- *@
@if (showModal)
{
    <div class="modal fade show" style="display:block;" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content" tabindex="0" @onkeydown="HandleKeyDown">
                <div class="modal-header">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button class="btn-close" @onclick="CloseModal" disabled="@saving"></button>
                </div>

                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(validationMessage))
                    {
                        <div class="alert alert-danger py-1">@validationMessage</div>
                    }

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Folio Number</label>
                            <input class="form-control" @bind="editModel.FolioNumber" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Holder</label>
                            <select class="form-select" @bind="editModel.FolioHolderId">
                                <option value="0">-- Select --</option>
                                @foreach (var h in _holders ?? Enumerable.Empty<FolioHolder>())
                                {
                                    <option value="@h.FolioHolderId">@h.FirstName @h.LastName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Fund</label>
                            <select class="form-select" @bind="editModel.FundId">
                                <option value="0">-- Select --</option>
                                @foreach (var f in _funds ?? Enumerable.Empty<Fund>())
                                {
                                    <option value="@f.FundId">@f.FundName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Purpose</label>
                            <input class="form-control" @bind="editModel.FolioPurpose" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Attached Bank</label>
                            <input class="form-control" @bind="editModel.AttachedBank" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="isActive" @bind="editModel.IsActive" />
                                <label class="form-check-label" for="isActive">Active</label>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseModal" disabled="@saving">Cancel</button>
                    <button class="btn btn-success" @onclick="Save" disabled="@saving">@(saving ? "Saving..." : "Save")</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

<style>
    .table-head-sm-bold th {
        font-weight: 600;
        font-size: .85rem;
        white-space: nowrap;
        vertical-align: middle;
    }

    th .th-sort {
        user-select: none;
        cursor: pointer;
        gap: .35rem;
        padding-right: .25rem;
        color: inherit;
    }

        th .th-sort:hover .th-title {
            color: #0d6efd;
            text-decoration: none;
        }

    th .th-caret {
        display: inline-flex;
        width: .9rem;
        justify-content: center;
        align-items: center;
        color: #6c757d;
    }
</style>

@code {
    private List<Folio>? _items;
    private List<FolioHolder>? _holders;
    private List<Fund>? _funds;

    // Filters
    private string? filterFolio;
    private string? filterHolder;
    private string? filterFund;
    private bool filterActiveOnly = false;

    // Sorting
    private string sortBy = "FolioNumber";
    private bool sortDesc = false;

    // Paging
    private int pageNumber = 1;
    private int _pageSize = 10;
    private int PageSize
    {
        get => _pageSize;
        set { if (_pageSize == value) return; _pageSize = value; pageNumber = 1; _ = Reload(); }
    }
    private int totalCount;
    private int totalPages => Math.Max(1, (int)Math.Ceiling((double)totalCount / _pageSize));
    private int FromRow => totalCount == 0 ? 0 : ((pageNumber - 1) * _pageSize) + 1;
    private int ToRow => Math.Min(pageNumber * _pageSize, totalCount);

    // Modal state
    private bool showModal = false;
    private bool isEdit = false;
    private bool saving = false;
    private string modalTitle = "Add Folio";
    private string? validationMessage;
    private Folio editModel = new();

    protected override async Task OnInitializedAsync()
    {
        // preload lists for dropdowns
        _holders = (await HolderRepo.GetAsync(nameContains: null, signatureContains: null, skip: 0, take: 1000)).Items.ToList();
        // Use a light fund load; adjust take if needed
        _funds = (await FundRepo.GetAsync(skip: 0, take: 1000)).Items.ToList();
        await Reload();
    }

    private async Task Reload()
    {
        var skip = (pageNumber - 1) * _pageSize;
        var (items, total) = await FolioRepo.GetAsync(
            folioContains: filterFolio,
            holderNameContains: filterHolder,
            fundNameContains: filterFund,
            onlyActive: filterActiveOnly ? true : null,
            skip: skip,
            take: _pageSize,
            sortBy: sortBy,
            desc: sortDesc);

        _items = items.ToList();
        totalCount = total;

        if (pageNumber > totalPages && totalPages > 0)
        {
            pageNumber = totalPages;
            await Reload();
            return;
        }
        StateHasChanged();
    }

    private async Task ApplyFilters() { pageNumber = 1; await Reload(); }
    private async Task ClearFilters()
    {
        filterFolio = filterHolder = filterFund = null;
        filterActiveOnly = false;
        pageNumber = 1;
        await Reload();
    }

    private async Task Sort(string column)
    {
        if (sortBy == column) sortDesc = !sortDesc;
        else { sortBy = column; sortDesc = false; }
        pageNumber = 1;
        await Reload();
    }

    private MarkupString SortGlyph(string column)
    {
        if (sortBy != column) return new MarkupString(string.Empty);
        var glyph = sortDesc ? "▾" : "▴";
        return new MarkupString($"<span class=\"ms-1\">{glyph}</span>");
    }
    private string AriaSort(string column) => sortBy != column ? "none" : (sortDesc ? "descending" : "ascending");

    // Paging handlers
    private async Task FirstPage() { if (pageNumber != 1) { pageNumber = 1; await Reload(); } }
    private async Task PrevPage() { if (pageNumber > 1) { pageNumber--; await Reload(); } }
    private async Task NextPage() { if (pageNumber < totalPages) { pageNumber++; await Reload(); } }
    private async Task LastPage() { if (pageNumber < totalPages) { pageNumber = totalPages; await Reload(); } }

    // Modal
    private void OpenAdd()
    {
        isEdit = false;
        modalTitle = "Add Folio";
        validationMessage = null;
        editModel = new Folio
        {
            IsActive = true
        };
        showModal = true;
    }

    private void OpenEdit(Folio src)
    {
        isEdit = true;
        modalTitle = "Edit Folio";
        validationMessage = null;

        editModel = new Folio
        {
            FolioId = src.FolioId,
            FolioNumber = src.FolioNumber,
            FolioPurpose = src.FolioPurpose,
            IsActive = src.IsActive,
            AttachedBank = src.AttachedBank,
            FolioHolderId = src.FolioHolderId,
            FundId = src.FundId,
            InDate = src.InDate,
            UpdateDate = src.UpdateDate
        };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Escape" or "Esc") showModal = false;
    }

    private async Task Save()
    {
        validationMessage = null;

        if (string.IsNullOrWhiteSpace(editModel.FolioNumber))
        { validationMessage = "Folio Number is required."; return; }
        if (editModel.FolioNumber.Length < 5 || editModel.FolioNumber.Length > 50)
        { validationMessage = "Folio Number should be 5–50 characters."; return; }
        if (editModel.FolioHolderId <= 0)
        { validationMessage = "Folio Holder is required."; return; }
        if (editModel.FundId <= 0)
        { validationMessage = "Fund is required."; return; }

        try
        {
            saving = true;

            if (isEdit) await FolioRepo.UpdateAsync(editModel);
            else await FolioRepo.AddAsync(editModel);

            showModal = false;
            await Reload();
        }
        catch (InvalidOperationException ex)
        {
            validationMessage = ex.Message; // duplicate composite, etc.
        }
        catch (DbUpdateException)
        {
            validationMessage = "Save failed due to a unique constraint or database error. Please review inputs.";
        }
        finally { saving = false; }
    }

    private async Task ConfirmDelete(int id, string display)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete folio “{display}”?"))
        {
            await FolioRepo.DeleteAsync(id);
            if (_items?.Count == 1 && pageNumber > 1) pageNumber--;
            await Reload();
        }
    }
}