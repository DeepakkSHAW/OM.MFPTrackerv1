@page "/folio-allocation"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "User,Admin")]

@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services
@using Microsoft.AspNetCore.Components
@using OM.MFPTrackerV1.Web.Components

@inject IFolioRepo FolioRepo
@inject IMutualFundTransactionRepo TxnRepo

<h3 class="mb-2">Investment Allocation by Folio</h3>

<p class="text-muted">
    Distribution of total invested amount across folios.
</p>

@if (isLoading)
{
    <p>Loading data…</p>
}
else if (values.Length == 0)
{
    <div class="alert alert-info">
        No investment data available.
    </div>
}
else
{
    <div style="height: 600px; overflow-y: auto;">
        <PieChart Labels="@labels" Values="@values" />
    </div>
}

@code {

    private string[] labels = [];
    private double[] values = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;

        // 1️⃣ Load all folios (no paging for allocation)
        var folios = await FolioRepo.GetAllAsync();

        // 2️⃣ Load aggregated investment totals by folio
        var totals = await TxnRepo.GetTotalInvestmentByFolioAsync();

        // 3️⃣ Prepare data for pie chart
        var data = folios
            .Select(f => new
            {
                Label = $"{f.FolioNumber} " +
                    $"[{f.AMC?.AMCName} - " +
                    $"{f.Holder?.FirstName} {f.Holder?.LastName}]",
                Value = totals.TryGetValue(f.FolioId, out var v) ? v : 0m
            })
            .Where(x => x.Value > 0)
            .OrderByDescending(x => x.Value)
            .ToList();

        labels = data
            .Select(x => x.Label)
            .ToArray();

        values = data
            .Select(x => (double)x.Value)
            .ToArray();

        isLoading = false;
    }
}