@page "/mf-category-allocation"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "User,Admin")]

@using OM.MFPTrackerV1.Data.Services
@using OM.MFPTrackerV1.Web.Components.ChartsComp

@inject IMFCategoryRepo Repo

<h3>Investment Allocation by Category</h3>
<p class="text-muted">
    Distribution of total invested amount across mutual fund categories.
</p>

@if (isLoading)
{
    <p>Loading data…</p>
}
else if (values.Length == 0)
{
    <div class="alert alert-info">
        No investment data available.
    </div>
}
else
{
    <PieChart Labels="@labels" Values="@values" />
    //@page "/mf-category-allocation"
}

@code {

    private string[] labels = [];
    private double[] values = [];

    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;

        var categories = await Repo.GetAllAsync();
        var totals = await Repo.GetTotalInvestmentByCategoryAsync();

        var data = categories
            .Select(c => new
            {
                c.CategoryName,
                Value = totals.TryGetValue(c.MFCatId, out var v) ? v : 0m
            })
            .Where(x => x.Value > 0)
            .OrderByDescending(x => x.Value)
            .ToList();

        labels = data.Select(x => x.CategoryName).ToArray();
        values = data.Select(x => (double)x.Value).ToArray();

        isLoading = false;
    }
}