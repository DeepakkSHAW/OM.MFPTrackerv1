<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <!-- Category -->
                <th role="button"
                    aria-sort="@AriaSort("CategoryName")"
                    title="Sort by Category"
                    @onclick='() => Sort("CategoryName")'>
                    Category @((MarkupString)SortGlyph("CategoryName").Value)
                </th>

                <!-- ✅ Total Investment -->
                <th role="button"
                    class="text-end text-nowrap"
                    style="width:200px;"
                    aria-sort="@AriaSort("TotalInvestment")"
                    title="Sort by Total Investment"
                    @onclick='() => Sort("TotalInvestment")'>
                    Investment (₹)
                    @((MarkupString)SortGlyph("TotalInvestment").Value)
                </th>

                <!-- Funds -->
                <th class="text-center" style="width:80px;">
                    Funds
                </th>

                <!-- Actions -->
                <th style="width:160px;"></th>
            </tr>
        </thead>

        <tbody>
            @if (_items is null)
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">
                        Loading...
                    </td>
                </tr>
            }
            else if (_items.Count == 0)
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">
                        No records found.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var x in _items)
                {
                    var fundCount =
                    _fundCounts.TryGetValue(x.MFCatId, out var c) ? c : 0;

                    var totalInv =
                    _investmentTotals.TryGetValue(x.MFCatId, out var t) ? t : 0m;

                    <tr>
                        <!-- Category -->
                        <td>@x.CategoryName</td>

                        <!-- ✅ Total Investment (compact + tooltip) -->
                        <td class="text-end money"
                            title="@totalInv.ToString("N2")">
                            @CurrencyFormatter.FormatAmount(totalInv)
                        </td>

                        <!-- Fund count -->
                        <td class="text-center">
                            @fundCount
                        </td>

                        <!-- Actions -->
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-secondary me-2"
                                    @onclick="() => OpenEdit(x)">
                                Edit
                            </button>

                            @if (fundCount > 0)
                            {
                                <button class="btn btn-sm btn-outline-danger"
                                        disabled
                                        title="Cannot delete: category has linked funds">
                                    Delete
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick='() => ConfirmDelete(x.MFCatId, x.CategoryName)'>
                                    Delete
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
<!-- Pagination -->
<div class="d-flex align-items-center justify-content-between">
    <div>Showing @FromRow–@ToRow of @totalCount</div>

    <div class="d-flex align-items-center gap-2">
        <div class="input-group input-group-sm" style="width:auto;">
            <span class="input-group-text">Page size</span>
            <select class="form-select form-select-sm"
                    style="width:auto"
                    @bind="PageSize">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>

        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(pageNumber == 1 ? "disabled" : null)">
                    <button class="page-link" @onclick="FirstPage">«</button>
                </li>
                <li class="page-item @(pageNumber == 1 ? "disabled" : null)">
                    <button class="page-link" @onclick="PrevPage">‹</button>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @pageNumber of @totalPages</span>
                </li>
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : null)">
                    <button class="page-link" @onclick="NextPage">›</button>
                </li>
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : null)">
                    <button class="page-link" @onclick="LastPage">»</button>
                </li>
            </ul>
        </nav>
    </div>
</div>

@* ================= Modal (Add & Edit) – UNCHANGED ================= *@
@if (showModal)
{
    <div class="modal fade show" style="display:block;" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog">
            <div class="modal-content" tabindex="0" @onkeydown="HandleKeyDown">
                <div class="modal-header">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button class="btn-close" @onclick="CloseModal" disabled="@saving"></button>
                </div>

                <EditForm Model="editModel" OnValidSubmit="Save" OnInvalidSubmit="OnInvalidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(validationMessage))
                        {
                            <div class="alert alert-danger py-1">@validationMessage</div>
                        }

                        <div class="mb-2">
                            <label class="form-label">Category Name</label>
                            <InputText class="form-control"
                                       @bind-Value="editModel.CategoryName"
                                       maxlength="50" />
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-outline-secondary"
                                @onclick="CloseModal"
                                disabled="@saving">
                            Cancel
                        </button>
                        <button type="submit"
                                class="btn btn-success"
                                disabled="@saving">
                            @(saving ? "Saving..." : "Save")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {

    private List<MFCategory>? _items;

    private Dictionary<int, int> _fundCounts = new();

    // ✅ NEW: Total Investment per category
    private Dictionary<int, decimal> _investmentTotals = new();

    // Filters
    private string? filterName;
    private string? filterMessage;

    // Sorting
    private string sortBy = "CategoryName";
    private bool sortDesc;

    // Paging
    private int pageNumber = 1;
    private int _pageSize = 10;

    private int PageSize
    {
        get => _pageSize;
        set
        {
            if (_pageSize == value) return;
            _pageSize = value;
            pageNumber = 1;
            _ = Reload();
        }
    }

    private int totalCount;
    private int totalPages => Math.Max(1,
        (int)Math.Ceiling((double)totalCount / _pageSize));

    private int FromRow =>
        totalCount == 0 ? 0 : ((pageNumber - 1) * _pageSize) + 1;

    private int ToRow =>
        Math.Min(pageNumber * _pageSize, totalCount);

    // Modal state (UNCHANGED)
    private bool showModal;
    private bool isEdit;
    private bool saving;
    private string modalTitle = "Add Category";
    private string? validationMessage;
    private MFCategory editModel = new();

    protected override async Task OnInitializedAsync()
        => await Reload();

    private async Task Reload()
    {
        var skip = (pageNumber - 1) * _pageSize;

        var (items, total) = await Repo.GetAsync(
            nameContains: filterName,
            skip: skip,
            take: _pageSize,
            sortBy: sortBy == "TotalInvestment" ? "CategoryName" : sortBy,
            desc: sortDesc);

        _items = items.ToList();
        totalCount = total;

        _fundCounts = await Repo.GetFundCountsAsync();

        // ✅ NEW – server-side aggregation
        _investmentTotals = await Repo.GetTotalInvestmentByCategoryAsync();

        // ✅ Client-side sort when sorting by investment
        if (sortBy == "TotalInvestment" && _items != null)
        {
            _items = (sortDesc
                ? _items.OrderByDescending(c =>
                    _investmentTotals.GetValueOrDefault(c.MFCatId))
                : _items.OrderBy(c =>
                    _investmentTotals.GetValueOrDefault(c.MFCatId)))
                .ToList();
        }

        if (pageNumber > totalPages && totalPages > 0)
        {
            pageNumber = totalPages;
            await Reload();
            return;
        }

        StateHasChanged();
    }

    private async Task ApplyFilters()
    {
        filterMessage = null;
        pageNumber = 1;
        await Reload();
    }

    private async Task ClearFilters()
    {
        filterName = null;
        filterMessage = null;
        pageNumber = 1;
        await Reload();
    }

    private async Task Sort(string column)
    {
        if (sortBy == column) sortDesc = !sortDesc;
        else { sortBy = column; sortDesc = false; }

        pageNumber = 1;
        await Reload();
    }

    private MarkupString SortGlyph(string column)
    {
        if (sortBy != column)
            return new MarkupString(string.Empty);

        var glyph = sortDesc ? "▾" : "▴";
        return new MarkupString($"<span class=\"ms-1\">{glyph}</span>");
    }

    private string AriaSort(string column)
        => sortBy != column
            ? "none"
            : (sortDesc ? "descending" : "ascending");

    private async Task FirstPage() { pageNumber = 1; await Reload(); }
    private async Task PrevPage() { pageNumber--; await Reload(); }
    private async Task NextPage() { pageNumber++; await Reload(); }
    private async Task LastPage() { pageNumber = totalPages; await Reload(); }

    private void OpenAdd()
    {
        isEdit = false;
        modalTitle = "Add Category";
        validationMessage = null;
        editModel = new MFCategory();
        showModal = true;
    }

    private void OpenEdit(MFCategory src)
    {
        isEdit = true;
        modalTitle = "Edit Category";
        validationMessage = null;
        editModel = new MFCategory
        {
            MFCatId = src.MFCatId,
            CategoryName = src.CategoryName
        };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Escape" or "Esc") showModal = false;
    }

    private void OnInvalidSubmit() => validationMessage = null;

    private async Task Save()
    {
        validationMessage = null;
        try
        {
            saving = true;
            if (isEdit) await Repo.UpdateAsync(editModel);
            else await Repo.AddAsync(editModel);

            showModal = false;
            await Reload();
        }
        catch (InvalidOperationException ex)
        {
            validationMessage = ex.Message;
        }
        catch (DbUpdateException)
        {
            validationMessage = "Save failed due to a database constraint.";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ConfirmDelete(int id, string display)
    {
        if (!await JS.InvokeAsync<bool>("confirm",
            $"Are you sure you want to delete “{display}”?"))
            return;

        try
        {
            await Repo.DeleteAsync(id);
            if (_items?.Count == 1 && pageNumber > 1) pageNumber--;
            await Reload();
        }
        catch (InvalidOperationException ex)
        {
            filterMessage = ex.Message;
        }
    }
}