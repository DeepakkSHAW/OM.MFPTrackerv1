@page "/mf-categories"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "User,Admin")]

@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Web.Helpers
@using OM.MFPTrackerV1.Data.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore

@inject IMFCategoryRepo Repo
@inject IJSRuntime JS

<h3>Mutual Fund Categories</h3>

<!-- Actions -->
<div class="d-flex gap-2 mb-3">
    <button class="btn btn-sm btn-success" @onclick="OpenAdd">Add Category</button>
</div>

<!-- Filters -->
<div class="card mb-3">
    <div class="card-body">

        <!-- Row 1 -->
        <div class="row g-2 mb-2">
            <div class="col-md-6">
                <label class="form-label mb-0 small fw-semibold">Category contains</label>
                <input class="form-control form-control-sm"
                       @bind="filterName"
                       placeholder="e.g., Equity" />
            </div>
        </div>

        <!-- Row 2 -->
        <div class="row g-2 align-items-end">
            <div class="col-md-6"></div>

            <div class="col-md-6 d-flex justify-content-end gap-2">
                <button class="btn btn-sm btn-primary" @onclick="ApplyFilters">Search</button>
                <button class="btn btn-sm btn-secondary" @onclick="ClearFilters">Clear</button>
                <a href="/mf-category-allocation" class="btn btn-sm btn-outline-primary">
                    View Category Allocation
                </a>

            </div>
        </div>

        @if (!string.IsNullOrEmpty(filterMessage))
        {
            <div class="alert alert-warning mt-2 py-1">@filterMessage</div>
        }
    </div>
</div>

