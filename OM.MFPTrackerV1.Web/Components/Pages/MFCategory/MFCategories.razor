@page "/mf-categories"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "User,Admin")]
@using OM.MFPTrackerV1.Data.Models
@using OM.MFPTrackerV1.Data.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.EntityFrameworkCore

@inject IMFCategoryRepo Repo
@inject IJSRuntime JS

<h3>Mutual Fund Categories</h3>

<!-- Actions -->
<div class="d-flex gap-2 mb-3">
    <button class="btn btn-sm btn-success" @onclick="OpenAdd">Add Category</button>
</div>

<!-- Filters (two-row compact layout) -->
<div class="card mb-3">
    <div class="card-body">
        <!-- Row 1 -->
        <div class="row g-2 mb-2">
            <div class="col-md-6">
                <label class="form-label mb-0 small fw-semibold">Category contains</label>
                <input class="form-control form-control-sm" @bind="filterName" placeholder="e.g., Equity" />
            </div>
        </div>

        <!-- Row 2 -->
        <div class="row g-2 align-items-end">
            <div class="col-md-6"></div>
            <div class="col-md-6 d-flex justify-content-end gap-2">
                <button class="btn btn-sm btn-primary" @onclick="ApplyFilters">Search</button>
                <button class="btn btn-sm btn-secondary" @onclick="ClearFilters">Clear</button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(filterMessage))
        {
            <div class="alert alert-warning mt-2 py-1">@filterMessage</div>
        }
    </div>
</div>

<!-- ===================== Table ===================== -->
<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th role="button"
                    aria-sort="@AriaSort("CategoryName")"
                    title="Sort by Category"
                    @onclick='() => Sort("CategoryName")'>
                    Category @((MarkupString)SortGlyph("CategoryName").Value)
                </th>

                <th style="width:120px;">
                    Funds
                </th>

                <th style="width:160px;"></th>
            </tr>
        </thead>

        <tbody>
            @if (_items is null)
            {
                <tr>
                    <td colspan="3" class="text-center text-muted">
                        Loading...
                    </td>
                </tr>
            }
            else if (_items.Count == 0)
            {
                <tr>
                    <td colspan="3" class="text-center text-muted">
                        No records found.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var x in _items)
                {
                    var count = _fundCounts.TryGetValue(x.MFCatId, out var c) ? c : 0;

                    <tr>
                        <td>@x.CategoryName</td>

                        <td>@count</td>

                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-secondary me-2"
                                    @onclick="() => OpenEdit(x)">
                                Edit
                            </button>

                            @if (count > 0)
                            {
                                <button class="btn btn-sm btn-outline-danger"
                                        disabled
                                        title="Cannot delete: category has linked funds">
                                    Delete
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick='() => ConfirmDelete(x.MFCatId, x.CategoryName)'>
                                    Delete
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
<!-- Pagination -->
<div class="d-flex align-items-center justify-content-between">
    <div>Showing @FromRow–@ToRow of @totalCount</div>
    <div class="d-flex align-items-center gap-2">
        <div class="input-group input-group-sm" style="width:auto;">
            <span class="input-group-text">Page size</span>
            <select class="form-select form-select-sm" style="width:auto" @bind="PageSize">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>

        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(pageNumber == 1 ? "disabled" : null)">
                    <button class="page-link" @onclick="FirstPage">«</button>
                </li>
                <li class="page-item @(pageNumber == 1 ? "disabled" : null)">
                    <button class="page-link" @onclick="PrevPage">‹</button>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @pageNumber of @totalPages</span>
                </li>
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : null)">
                    <button class="page-link" @onclick="NextPage">›</button>
                </li>
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : null)">
                    <button class="page-link" @onclick="LastPage">»</button>
                </li>
            </ul>
        </nav>
    </div>
</div>

@* ---------------- Modal (JS-free; Add & Edit) — EditForm + ValidationSummary (Option B) ---------------- *@
@if (showModal)
{
    <div class="modal fade show" style="display:block;" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog">
            <div class="modal-content" tabindex="0" @onkeydown="HandleKeyDown">
                <div class="modal-header">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button class="btn-close" @onclick="CloseModal" disabled="@saving"></button>
                </div>

                <EditForm Model="editModel" OnValidSubmit="Save" OnInvalidSubmit="OnInvalidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="modal-body">
                        @* Only show repo/DB errors here *@
                        @if (!string.IsNullOrEmpty(validationMessage))
                        {
                            <div class="alert alert-danger py-1">@validationMessage</div>
                        }

                        <div class="mb-2">
                            <label class="form-label">Category Name</label>
                            <InputText class="form-control"
                                       @bind-Value="editModel.CategoryName"
                                       maxlength="50"
                                       pattern="[A-Za-z0-9 \-&() _-]{3,50}"
                                       title="Letters, numbers, spaces, - & ( ) allowed; 3–50 characters" />
                            <small class="text-muted">Alphanumeric; 3–50 chars; case-insensitive unique</small>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal" disabled="@saving">Cancel</button>
                        <button type="submit" class="btn btn-success" disabled="@saving">
                            @(saving ? "Saving..." : "Save")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<MFCategory>? _items;
    private Dictionary<int, int> _fundCounts = new();

    // Filters
    private string? filterName;
    private string? filterMessage;

    // Sorting
    private string sortBy = "CategoryName";
    private bool sortDesc = false;

    // Paging
    private int pageNumber = 1;
    private int _pageSize = 10;
    private int PageSize
    {
        get => _pageSize;
        set
        {
            if (_pageSize == value) return;
            _pageSize = value;
            pageNumber = 1;
            _ = Reload(); // fire-and-forget
        }
    }

    private int totalCount;
    private int totalPages => Math.Max(1, (int)Math.Ceiling((double)totalCount / _pageSize));
    private int FromRow => totalCount == 0 ? 0 : ((pageNumber - 1) * _pageSize) + 1;
    private int ToRow => Math.Min(pageNumber * _pageSize, totalCount);

    // Modal
    private bool showModal = false;
    private bool isEdit = false;
    private bool saving = false;
    private string modalTitle = "Add Category";
    private string? validationMessage;
    private MFCategory editModel = new();

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        var skip = (pageNumber - 1) * _pageSize;

        var (items, total) = await Repo.GetAsync(
            nameContains: filterName,
            skip: skip,
            take: _pageSize,
            sortBy: sortBy,
            desc: sortDesc);

        _items = items.ToList();
        totalCount = total;

        // Load fund counts
        _fundCounts = await Repo.GetFundCountsAsync();

        if (pageNumber > totalPages && totalPages > 0)
        {
            pageNumber = totalPages;
            await Reload();
            return;
        }
        StateHasChanged();
    }

    private async Task ApplyFilters()
    {
        filterMessage = null;
        pageNumber = 1;
        await Reload();
    }

    private async Task ClearFilters()
    {
        filterName = null;
        filterMessage = null;
        pageNumber = 1;
        await Reload();
    }

    // Sorting
    private async Task Sort(string column)
    {
        if (sortBy == column) sortDesc = !sortDesc;
        else { sortBy = column; sortDesc = false; }
        pageNumber = 1;
        await Reload();
    }

    private MarkupString SortGlyph(string column)
    {
        if (sortBy != column) return new MarkupString(string.Empty);
        var glyph = sortDesc ? "▾" : "▴";
        return new MarkupString($"<span class=\"ms-1\">{glyph}</span>");
    }
    private string AriaSort(string column) => sortBy != column ? "none" : (sortDesc ? "descending" : "ascending");

    // Paging handlers
    private async Task FirstPage() { if (pageNumber != 1) { pageNumber = 1; await Reload(); } }
    private async Task PrevPage() { if (pageNumber > 1) { pageNumber--; await Reload(); } }
    private async Task NextPage() { if (pageNumber < totalPages) { pageNumber++; await Reload(); } }
    private async Task LastPage() { if (pageNumber < totalPages) { pageNumber = totalPages; await Reload(); } }

    // Modal control
    private void OpenAdd()
    {
        isEdit = false;
        modalTitle = "Add Category";
        validationMessage = null;
        editModel = new MFCategory();
        showModal = true;
    }

    private void OpenEdit(MFCategory src)
    {
        isEdit = true;
        modalTitle = "Edit Category";
        validationMessage = null;
        editModel = new MFCategory
        {
            MFCatId = src.MFCatId,
            CategoryName = src.CategoryName
        };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Escape" or "Esc") showModal = false;
    }

    private void OnInvalidSubmit()
    {
        // Form failed DataAnnotations validation; hide any stale repo/DB banner
        validationMessage = null;
    }

    // Save (DataAnnotations validated by EditForm)
    private async Task Save()
    {
        validationMessage = null;

        try
        {
            saving = true;

            if (isEdit) await Repo.UpdateAsync(editModel);
            else await Repo.AddAsync(editModel);

            showModal = false;
            await Reload();
        }
        catch (InvalidOperationException ex)
        {
            validationMessage = ex.Message; // duplicate name etc.
        }
        catch (DbUpdateException)
        {
            validationMessage = "Save failed due to a unique constraint or database error. Please check the category name.";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ConfirmDelete(int id, string display)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete “{display}”?")) return;

        try
        {
            await Repo.DeleteAsync(id);
            if (_items?.Count == 1 && pageNumber > 1) pageNumber--;
            await Reload();
        }
        catch (InvalidOperationException ex)
        {
            // Friendly message: category has linked funds
            filterMessage = ex.Message;
            StateHasChanged();
        }
    }
}