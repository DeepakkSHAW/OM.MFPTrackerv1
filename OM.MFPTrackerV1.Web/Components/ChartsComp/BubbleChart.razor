@using OM.MFPTrackerV1.Web.Models.ViewModels
@inject IJSRuntime JS

<div style="width:100%; height:100%;">
    <canvas id="@_canvasId"></canvas>
</div>

@code {

    private readonly string _canvasId =
        $"bubble-{Guid.NewGuid()}";

    /// <summary>
    /// Bubble chart data. Each item represents one bubble.
    /// </summary>
    [Parameter, EditorRequired]
    public IReadOnlyList<BubbleChartPoint> Data { get; set; } = Array.Empty<BubbleChartPoint>();

    private int _lastHash;


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Data.Count == 0)
            return;

        var hash = Data.Count ^ Data.First().X.GetHashCode();
        if (hash == _lastHash)
            return;

        _lastHash = hash;

        // ✅ Convert DateTime -> Unix ms here (NOT in DTO)
        var datasets = Data
            .GroupBy(p => p.ColorKey)
            .Select(g => new
            {
                label = $"{g.First().Fund} – {g.First().Holder}",
                colorKey = g.Key,
                // data = g.Select(p => new
                // {
                //     x = new DateTimeOffset(p.X).ToUnixTimeMilliseconds(),
                //     y = (double)p.Y,
                //     r = Math.Log10((double)p.Investment + 1) * 6,
                //     fund = p.Fund,
                //     holder = p.Holder,
                //     investment = (double)p.Investment
                // })

                data = g.Select(p => new
                {
                    x = new DateTimeOffset(p.X).ToUnixTimeMilliseconds(),
                    y = (double)p.Y,
                    r = Math.Clamp(
                        Math.Log10((double)p.Investment + 1) * 4 - 7,
                        1,
                        40
                    ),
                    fund = p.Fund,
                    holder = p.Holder,
                    investment = (double)p.Investment
                })

            });

        await JS.InvokeVoidAsync(
            "chartInterop.renderBubbleChartFromPointData",
            _canvasId,
            datasets
        );
    }


